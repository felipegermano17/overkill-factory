  "product_security_checks": ["Product-level check"],
  "code_security_checks": ["Code-level check"],
  "system_security_checks": ["System-level check"],
  "process_security_checks": ["Process-level check"],
  "verify_commands": ["command or manual check"],
  "evidence_expected": ["Expected evidence"],
  "review": {
    "QA_required": false,
    "independent_review_required": false,
