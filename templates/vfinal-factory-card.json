{
  "$schema": "https://overkill-factory.dev/schemas/factory-card.schema.json",
  "card_id": "OF-VFINAL-001",
  "slice_id": "PRODUCT_SLICE_ID",
  "owner_profile": "factory-orchestrator",
  "request_type": "product_new",
  "canonical_product_sot_ref": "product_sot",
  "scope_intent": "full_product",
  "complete_product_required": true,
  "current_execution_slice": "first safe execution slice only; not a Product SOT scope reduction",
  "full_product_sot_scope_coverage_ref": "templates/full-product-sot-scope-coverage.json",
  "specialist_research_plan_ref": "templates/specialist-research-plan.json",
  "specialist_decision_packet_ref": "templates/specialist-decision-packet.json",
  "production_promotion_ladder_ref": "templates/production-promotion-ladder.json",
  "product_creation_plan_ref": "templates/product-creation-plan.json",
  "product_context_packet_ref": "templates/product-context-packet.json",
  "product_implementation_readiness_ref": "templates/product-implementation-readiness.json",
  "user_facing_autonomy_contract_ref": "templates/user-facing-autonomy-contract.json",
  "source_refs": ["source-ledger.md"],
  "source_state": "promoted",
  "outcome": "Describe the concrete result this card must produce.",
  "acceptance_criteria": ["observable acceptance criterion"],
  "scope_in": ["what the worker may do"],
  "scope_out": ["what the worker must not do"],
  "risk_class": "R2-product-work",
  "codex_mode": "plan_and_execute_with_gates",
  "review": {
    "independent_review_required": true,
    "human_gate_required": false
  },
  "factory_method_version": "OVERKILL_VFINAL",
  "phase": "F11",
  "surfaces": ["code"],
  "capability_coverage_required": true,
  "risk_initial": "R2",
  "risk_effective": "R2",
  "authority_max": "bounded_execution",
  "owner_worker": "factory-orchestrator",
  "executor_identity": "implementation-worker",
  "reviewer_identity": "independent-reviewer",
  "runtime_decision": "hermes_default",
  "runtime_contract": { "mode": "bounded_worker" },
  "security_contract": { "security_boundary": "no_sensitive_action" },
  "forbidden_actions": ["deploy", "secret_access", "billing_change"],
  "done_definition": ["work implemented", "tests pass", "review complete"],
  "transition_event_required": true,
  "kanban_transition_event_ref": "required_before_ready",
  "target_repo_paths": ["src/or/docs"],
  "outcome_contract": {
    "$schema": "https://overkill-factory.dev/schemas/outcome-contract.schema.json",
    "outcome": "Concrete product result.",
    "users_or_actors": ["target user"],
    "problem": "Problem to solve.",
    "success_signals": ["observable signal"],
    "non_goals": ["out of scope"],
    "open_questions": [],
    "evidence_refs": ["source-ledger.md"],
    "behavior_change": "Expected behavior change after this slice exists.",
    "risk_signals": ["observable sign that the product may fail or be unsafe"],
    "assumptions": ["assumption tracked before execution"],
    "human_questions": [],
    "discovery_depth": "standard"
  },
  "user_facing_autonomy_contract": {
    "$schema": "https://overkill-factory.dev/schemas/user-facing-autonomy-contract.schema.json",
    "record_type": "user_facing_autonomy_contract",
    "intake_source": "mixed",
    "user_roles": ["submitter", "approver", "reviewer", "access_provider", "risk_owner"],
    "factory_owns": [
      "source resolution",
      "Product SOT candidate creation",
      "method routing",
      "specialist research routing",
      "architecture and security planning",
      "capability pack selection",
      "decomposition and worker packet creation",
      "execution routing",
      "verification and independent review",
      "evidence capture",
      "completion audit and Receipt Five preparation"
    ],
    "user_must_not_do": [
      "coordinate internal workers",
      "manually assemble worker packets",
      "operate schemas or internal gates",
      "search internal evidence artifacts",
      "decide method internals without a bounded approval request"
    ],
    "allowed_user_question_classes": [
      "preference",
      "authority_required",
      "access_required",
      "risk_acceptance",
      "blocked"
    ],
    "user_questions": [],
    "human_gate_triggers": [
      "production release",
      "mainnet or funds",
      "credential or secret access",
      "privacy, legal or security-sensitive decision",
      "destructive or irreversible action",
      "major scope or risk acceptance"
    ],
    "approval_points": [
      "Product SOT approval when material scope is unresolved",
      "architecture approval when risk or cost is material",
      "access approval when credentials or accounts are required",
      "release approval for production or irreversible promotion",
      "final acceptance after evidence and review"
    ],
    "autonomy_level": "gated_autonomous_execution",
    "handoff_mode": "compressed operator view with understanding, bounded decisions, blockers, proof and next action",
    "blocked_state_policy": "stop with a named blocker, owner, evidence needed and smallest safe next action instead of pushing open-ended work to the user",
    "burden_budget": [
      {
        "phase": "intake",
        "allowed_user_work": ["provide material, intent and constraints"],
        "factory_work": ["classify input and start source resolution"]
      },
      {
        "phase": "planning",
        "allowed_user_work": ["approve or reject material scope and risk decisions"],
        "factory_work": ["create Product SOT, route methods, research and plans"]
      },
      {
        "phase": "execution",
        "allowed_user_work": ["provide access only when required"],
        "factory_work": ["route workers, run checks, capture evidence and review"]
      },
      {
        "phase": "promotion",
        "allowed_user_work": ["approve high-risk release or risk acceptance"],
        "factory_work": ["prepare promotion evidence, rollback and monitoring"]
      },
      {
        "phase": "completion",
        "allowed_user_work": ["review final proof and acceptance"],
        "factory_work": ["reconcile Receipt Five and completion audit"]
      }
    ],
    "surface_map": [
      {
        "capability": "worker packets",
        "internal": true,
        "user_facing": false,
        "maintainer_facing": true,
        "normal_user_view": "factory is preparing worker tasks"
      },
      {
        "capability": "human gates",
        "internal": false,
        "user_facing": true,
        "maintainer_facing": true,
        "normal_user_view": "bounded approval request with scope, risk and evidence"
      },
      {
        "capability": "evidence graph",
        "internal": true,
        "user_facing": true,
        "maintainer_facing": true,
        "normal_user_view": "what evidence proves progress"
      }
    ]
  },
  "product_sot": {
    "$schema": "https://overkill-factory.dev/schemas/product-sot.schema.json",
    "what_it_is": "A short, concrete description of the complete product defined by the approved Product SOT.",
    "target_users": ["primary user or actor"],
    "why_it_matters": "Why this outcome is worth building now.",
    "outcome": "The result the product must create.",
    "scope_in": ["included behavior or deliverable"],
    "scope_out": ["explicit non-goal"],
    "risks": ["material product, technical, security or operational risk"],
    "authority": "Who may approve scope, execution, release or waiver.",
    "data_and_metrics": ["success metric or risk metric that matters"],
    "dependencies": ["external or internal dependency"],
    "access_and_capabilities": ["repo/cloud/API/account/tool access required"],
    "compliance_privacy": ["privacy, legal, license or compliance note"],
    "cost_relevance": "No material spend, or named budget/cost boundary.",
    "operations_expected": ["how the product is expected to run or be supported"],
    "success_criteria": ["observable criterion for success"],
    "full_product_sot_scope_coverage_ref": "templates/full-product-sot-scope-coverage.json",
    "research_decision_refs": ["templates/specialist-decision-packet.json"],
    "research_confirmations": ["research decisions that confirm or change Product SOT requirements"],
    "open_decisions": [],
    "evidence_refs": ["source-ledger.md"]
  },
  "method_contract": {
    "$schema": "https://overkill-factory.dev/schemas/method-contract.schema.json",
    "selected_method": "spec-first",
    "why_this_method": "Risk and scope require a written plan before implementation.",
    "risk_tier": "R2",
    "required_plans": ["software_development_plan"],
    "required_gates": ["Ready Gate", "Review Gate", "Done Gate"],
    "waivers": [],
    "canonical_scope_source": "approved Product SOT",
    "scope_intent": "full_product",
    "factory_route": "complete-product-production",
    "required_factory_artifacts": [
      "full_product_sot_scope_coverage",
      "product_creation_plan",
      "product_implementation_readiness"
    ],
    "engineering_method_matrix": [
      {
        "surface_or_component": "product core",
        "methods": ["spec-first", "test-first"],
        "reason": "Product SOT requirements need stable contracts and regression proof.",
        "required_artifacts": ["spec_graph", "work_unit_contract"],
        "evidence_required": ["tests pass", "worker result evidence"]
      }
    ],
    "slice_execution_policy": {
      "slices_are_execution_units_only": true,
      "canonical_scope_must_not_shrink": true,
      "first_slice_completion_is_not_product_completion": true
    },
    "production_route_decision": "Use the production promotion ladder when product intent reaches customers, production, mainnet or irreversible release.",
    "research_decision_refs": ["templates/specialist-decision-packet.json"],
    "research_route_impacts": ["research decisions may add gates, methods, workers or proof requirements"],
    "work_type": "feature",
    "selected_methods": ["spec-first"],
    "skipped_methods": [
      {
        "method": "prototype-first",
        "reason": "No material uncertainty that requires prototype before planning."
      }
    ],
    "required_artifacts": ["software_development_plan", "spec_graph", "loop_plan"],
    "required_workers": ["factory-orchestrator", "decomposition-planner", "qa-verification-worker", "independent-reviewer"],
    "reviewers": ["independent-reviewer"],
    "evidence_requirements": ["tests pass", "independent review", "Receipt Five"],
    "authority_limit": "bounded_execution only; no release without gate",
    "done_criteria": ["required artifacts exist", "required workers returned evidence", "Receipt Five ready"]
  },
  "capability_pack_contract": {
    "$schema": "https://overkill-factory.dev/schemas/capability-pack-contract.schema.json",
    "record_type": "capability_pack_contract",
    "pack_id": "web-saas-core",
    "status": "ready",
    "covered_surfaces": ["code"],
    "specialist_workers": ["implementation-worker", "qa-verification-worker", "independent-reviewer"],
    "activation_evidence_refs": ["agents/capability-packs.public.json#web-saas-core"],
    "missing_capabilities": [],
    "execution_rule": "Execution can start only when every specialized surface is covered by a ready core pack or an activated modular pack.",
    "product_pack_id": "generic-software-product",
    "product_pack_version": "v1",
    "surface_pack_id": "code",
    "risk_addendum": ["R2 requires independent review"],
    "templates_required": ["templates/software-development-plan.json", "templates/spec-graph.json", "templates/loop-plan.json"],
    "evidence_required": ["test output", "review result", "Receipt Five"],
    "worker_mapping": {
      "build": ["implementation-worker"],
      "verify": ["qa-verification-worker"],
      "review": ["independent-reviewer"]
    }
  },
  "reasoning_policy": {
    "$schema": "https://overkill-factory.dev/schemas/reasoning-policy.schema.json",
    "record_type": "reasoning_policy",
    "reasoning_class": "standard",
    "allowed_profile_classes": ["bounded-worker", "review-capable-worker"],
    "review_intensity": "independent_review",
    "evidence_policy": {
      "durable_summary_required": true,
      "raw_chain_of_thought_forbidden": true,
      "evidence_refs_required": true
    },
    "private_reasoning_policy": "summarize_only",
    "block_when": [
      "selected profile cannot satisfy reasoning class",
      "required review intensity is unavailable",
      "worker result lacks durable evidence"
    ],
    "derived_from": ["risk_effective", "phase", "surfaces", "authority_max"]
  },
  "reference_quality_packet": {
    "$schema": "https://overkill-factory.dev/schemas/reference-quality-packet.schema.json",
    "record_type": "reference_quality_packet",
    "experience_category": "software product surface",
    "quality_bar": "Specific, product-fit experience that avoids generic generated UI.",
    "anti_generic_criteria": [
      "The output must reflect the product job, not a generic demo.",
      "Design direction must be concrete enough for Product Face review."
    ],
    "references": [
      {
        "source_id": "operator-approved-benchmark",
        "source_url_or_ref": "external:operator-approved-reference",
        "use_type": "benchmark",
        "what_to_learn": ["quality bar", "interaction expectations"],
        "copy_policy": "do_not_copy",
        "license_or_terms_ref": "not_applicable_for_benchmark_only",
        "public_safety_notes": "Benchmark only; no copied text, code or assets."
      }
    ],
    "design_rationale": "The reference packet feeds Product Experience and Product Face before implementation.",
    "component_expectations": ["components fit the job-to-be-done"],
    "interaction_expectations": ["states and transitions are observable"],
    "visual_constraints": ["avoid generic generated composition"],
    "reuse_policy": {
      "allowed": ["benchmarking", "inspiration"],
      "forbidden": ["blind copy", "unlicensed code or asset reuse"],
      "license_required_for_code_or_assets": true
    },
    "accessibility_constraints": ["keyboard path", "labels", "contrast"],
    "performance_constraints": ["no decorative work that blocks the primary task"],
    "acceptance_criteria": ["Product Face design-fit review passes"],
    "product_experience_fields_informed": ["experience_sot", "design_direction", "proof_required"]
  },
  "learning_proposal_refs": [
    "templates/factory-learning-proposal.json"
  ],
  "software_development_plan": {
    "$schema": "https://overkill-factory.dev/schemas/software-development-plan.schema.json",
    "work_units": ["bounded implementation slice traced to Product SOT requirements"],
    "work_unit_contracts": ["templates/work-unit-contract.json"],
    "qa_plan": ["run the checks named in the card before done"],
    "review_plan": ["route review from changed surfaces and risk"],
    "reviewer_selection_plan": "templates/reviewer-selection-plan.json",
    "release_or_block_rule": "release only when evidence, review and gates pass",
    "evidence_refs": ["source-ledger.md"],
    "required_artifacts": ["PRD", "TRD", "Factory Card", "Test Plan", "Release Plan"],
    "skipped_artifacts": [],
    "prd": "Product behavior and scope summary derived from Product SOT.",
    "trd": "Technical route, boundaries and integration notes.",
    "domain_map": ["main domain object or workflow"],
    "acceptance_examples": ["Given/when/then or concrete acceptance scenario"],
    "stories": ["bounded user or system story"],
    "factory_cards": ["this card plus child cards when needed"],
    "full_product_plan": [
      "map every meaningful Product SOT requirement to work, proof, blocker, deferred item, explicit non-goal or human decision"
    ],
    "slice_plan": ["first executable slice; this does not reduce Product SOT scope"],
    "slice_execution_plan": [
      "execute only ready slices whose work-unit contracts include verification, expected result, STOP conditions and evidence refs"
    ],
    "test_plan": ["unit/integration/e2e checks that prove acceptance"],
    "security_architecture_ref": "security_contract or security_architecture_plan when required",
    "legacy_migration_decision": "not_needed",
    "platform_devex_decision": "not_needed",
    "release_plan": ["release or block after proof"],
    "documentation_plan": ["update user or operator docs if behavior changes"]
  },
  "reviewer_selection_plan": {
    "record_type": "reviewer_selection_plan",
    "changed_surfaces": ["code"],
    "risk_effective": "R2",
    "executor_identity": "implementation-worker",
    "forbidden_reviewers": ["implementation-worker"],
    "required_reviewers": ["independent-reviewer"],
    "reviewer_matrix": [
      {
        "reviewer_worker": "independent-reviewer",
        "covers": ["code", "evidence"],
        "reason": "Material work needs review by a worker that did not execute it.",
        "mandatory": true
      }
    ],
    "selection_rule": "Pick reviewers from changed surfaces and exclude the executor.",
    "evidence_refs": ["source-ledger.md"]
  },
  "spec_graph": {
    "$schema": "https://overkill-factory.dev/schemas/spec-graph.schema.json",
    "requirements": ["requirement or card objective"],
    "outcome_links": ["outcome_contract", "product_sot"],
    "examples": ["acceptance example or scenario"],
    "decisions": ["method_contract selected_method"],
    "risks": ["risk_effective and risk owner"],
    "dependencies": ["dependency map or explicit not_needed"],
    "access_needs": ["autonomy_readiness_packet or explicit not_needed"],
    "security_architecture_refs": ["security_contract or security_architecture_plan"],
    "data_refs": ["data_metrics_plan or explicit not_needed"],
    "gates": ["Ready Gate", "Review Gate", "Done Gate"],
    "workers": ["factory-orchestrator", "decomposition-planner", "qa-verification-worker", "independent-reviewer"],
    "proofs": ["test output", "review result", "Receipt Five"],
    "evidence_refs": ["spec-graph.md"]
  },
  "loop_plan": {
    "$schema": "https://overkill-factory.dev/schemas/loop-plan.schema.json",
    "unit_of_work": "one bounded implementation slice",
    "work_unit_contract_ref": "templates/work-unit-contract.json",
    "verify": ["test command"],
    "review": ["independent review"],
    "reviewer_selection_ref": "templates/reviewer-selection-plan.json",
    "rollback": "revert the slice without touching unrelated work",
    "evidence_refs": ["source-ledger.md"],
    "lanes": ["implementation", "verification", "review"],
    "order": ["plan", "build", "verify", "review", "reconcile"],
    "inputs": ["method_contract", "software_development_plan", "work_unit_contract"],
    "workers": ["implementation-worker", "qa-verification-worker", "independent-reviewer", "evidence-reconciler"],
    "limits": ["do not touch out-of-scope paths", "no production mutation"],
    "timeouts": ["stop and block after repeated failure or missing access"],
    "budget": "no material spend without Budget Gate",
    "access_required": ["repo read/write according to card authority"],
    "expected_evidence": ["test output", "review result", "Receipt Five readiness"],
    "stop_criteria": ["done definition satisfied"],
    "block_criteria": ["missing access", "failing tests", "missing review", "missing evidence"]
  },
  "product_experience_plan": {
    "$schema": "https://overkill-factory.dev/schemas/product-experience-plan.schema.json",
    "surface_type": "software product",
    "surface_pack": "generic-product-surface-pack",
    "experience_sot": "The operator can understand the work, states, evidence and next action without private context.",
    "user": "target user or operator",
    "job_to_be_done": "Use the produced surface or workflow with clear status, states and evidence.",
    "main_flows": ["primary product flow"],
    "required_states": ["ready", "blocked", "done"],
    "design_direction": {
      "visual_tone": "clear and product-specific",
      "product_fit": "Interface and docs must fit the product job, not a generic demo.",
      "density": "appropriate to repeated operational use",
      "interaction_style": "direct, observable and reversible when risk exists"
    },
    "visual_quality_bar": {
      "reference_quality_bar": "A product-specific operator surface benchmark, existing product convention or best-in-class reference class named before execution.",
      "anti_generic_criteria": [
        "no generic AI dashboard composition",
        "no excessive explanatory copy where structure and interaction should carry meaning",
        "no templated visual hierarchy disconnected from the user job"
      ],
      "professional_review_required": true,
      "block_when": [
