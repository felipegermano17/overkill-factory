      "implementation-worker": "agents/hermes-profile-bindings.public.json#implementation-worker",
      "qa-verification-worker": "agents/hermes-profile-bindings.public.json#qa-verification-worker",
      "independent-reviewer": "agents/hermes-profile-bindings.public.json#independent-reviewer"
    },
    "permission_class": "bounded-worker",
    "missing_capabilities": [],
    "execution_rule": "Execution can start only when every specialized surface is covered by a ready core pack or an activated modular pack.",
