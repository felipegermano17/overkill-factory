{
  "$schema": "https://overkill-factory.dev/schemas/secret-delivery-policy.schema.json",
  "record_type": "secret_delivery_policy",
  "secret_type": "other",
  "sensitivity": "public_test",
  "environment": "local",
  "delivery_mode": "placeholder",
  "scope": "no real credential; placeholder or simulator only",
  "ttl_or_expiry": "not applicable for placeholder mode",
  "rotation_policy": "replace with scoped JIT or user-mediated access before real secrets are needed",
  "audit_log_ref": "external:secret-delivery-audit-not-required-for-placeholder",
  "redaction_policy": "secret values must never enter prompts, logs, memory, files, subprocesses or public artifacts",
  "revocation_path": "not applicable for placeholder mode",
  "human_gate_required": false,
  "allowed_worker_ids": ["factory-orchestrator"],
  "forbidden_exposure": ["prompt", "memory", "logs", "env", "files", "subprocesses", "browser", "public_artifact"],
  "evidence_refs": ["templates/secret-delivery-policy.json"]
}
