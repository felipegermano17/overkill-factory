      "authority_max": "classify source status; cannot promote decisions alone",
      "veto_conditions": [
        "source mixed with inference",
        "unresolved contradiction hidden"
      ],
      "evidence_required": [
        "source map",
        "conflict list",
        "gap list"
      ],
      "kanban_transition_rules": [
        "Product SOT waits for source resolution"
      ],
      "promotion_rule": "stays open while source shapes remain unpredictable",
      "public_safety_notes": "Raw extraction stays outside the public repo."
