        "risk_effective",
        "surfaces",
        "done_definition"
      ],
      "tools": [
        "Hermes Kanban",
        "factoryctl gate-report"
      ],
      "output_contract": "orchestration_result",
      "authority_max": "route and block; cannot approve gates",
      "veto_conditions": [
        "missing phase",
        "missing risk",
        "missing evidence chain"
      ],
      "evidence_required": [
        "gate report",
        "routing decision",
        "next action"
      ],
      "kanban_transition_rules": [
        "never unblock R3/R4 without required gates"
      ],
      "promotion_rule": "hybrid worker remains supervised; closed subflows only after repeated success",
      "public_safety_notes": "No private board ids or runtime paths."
