{
  "$schema": "https://overkill-factory.dev/schemas/worker-registry.schema.json",
  "registry_version": "factory-11",
  "workers": [
    {
      "worker_id": "factory-orchestrator",
      "mode": "hybrid",
      "phase": [
        "F0",
        "F18"
      ],
      "triggers": [
        "phase change",
        "blocked work",
        "worker routing"
      ],
      "inputs": [
