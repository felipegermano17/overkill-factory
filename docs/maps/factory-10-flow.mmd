  F6 --> W9["solana-quasar-auditor | hybrid | Auditor, PDA, CPI, CU"]:::worker
  F14 --> W10["autoreview-gate | closed | pre-landing code review"]:::worker
  F14 --> W11["remote-proof-runner | closed | Crabbox/Testbox/container"]:::worker
  F15 --> W12["independent-reviewer | hybrid | executor diferente"]:::worker
  F16 --> W13["handoff-packer | closed | estado e replay"]:::worker
  F18 --> W14["public-safety-gate | closed | sem vazamento publico"]:::worker
  F19 --> W15["detection-monitoring-worker | hybrid | logs, alertas, incidente"]:::worker
  F20 --> W16["skill-eval-distiller | hybrid | skill so com eval"]:::worker
  F20 --> W17["memory-steward | hybrid | trust tier e poisoning"]:::worker

  F11 --> A1["Alerta: worker packet nao e worker result"]:::alert
  F16 --> A2["Alerta: gate report nao e evidencia final"]:::alert
  F14 --> A3["Alerta: AutoReview nao aprova sozinho"]:::alert
  F14 --> A4["Alerta: Auditor preflight nao e auditoria de codigo real"]:::alert
  F18 --> A5["Alerta: dry pilot nao e producao"]:::alert

  LEGEND0["Como ler o mapa"]:::review
  LEGEND1["Caixa colorida = etapa da fabrica"]:::planning
  LEGEND2["Caixa cinza na frente = o que aquela etapa faz"]:::desc
  LEGEND3["Seta principal = ordem real de producao"]:::learning
  LEGEND4["Seta lateral = detalhe, alerta ou prova"]:::architecture
  LEGEND5["Verde = fonte, evidencia, resultado ou aprendizado"]:::source
  LEGEND6["Azul = organizacao, documentacao ou operacao"]:::planning
  LEGEND7["Roxo = revisao critica ou especialista"]:::review
  LEGEND8["Laranja = arquitetura, promocao ou decisao dificil"]:::architecture
  LEGEND9["Amarelo = aprovacao humana"]:::human
  LEGEND10["Vermelho = gate rigido, bloqueio ou risco"]:::gate
  LEGEND11["Prata = explicacao simples"]:::desc

