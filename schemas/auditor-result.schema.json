{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/auditor-result.schema.json",
  "title": "Overkill Factory Auditor Result",
  "type": "object",
  "required": [
    "record_type",
    "result",
    "audit_mode",
    "tool_or_profile",
    "executed_by",
    "blocking_findings",
    "findings_summary",
    "evidence_refs",
    "next_action"
  ],
  "properties": {
    "record_type": { "const": "auditor_result" },
    "result": { "enum": ["PASS", "FAIL", "WAIVED", "PENDING"] },
    "audit_mode": { "enum": ["preflight", "code_audit"] },
    "preflight_only": { "type": "boolean" },
    "auditor_head": { "type": "string" },
    "corpus_files_loaded": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "checklist_coverage": { "type": "object" },
    "known_vectors_coverage": { "type": "object" },
    "instruction_matrix": {
      "type": "array",
      "items": { "type": "object" }
    },
    "state_model": { "type": "object" },
    "quasar_toolchain_proof": {
      "type": "object",
      "required": [
        "install_source",
        "source_head",
        "rustc",
        "cargo",
        "solana",
        "quasar",
        "init_command",
        "build_command",
        "test_command",
        "build_status",
        "test_status",
        "evidence_refs"
      ],
      "properties": {
        "install_source": { "type": "string", "minLength": 1 },
        "source_head": { "type": "string", "minLength": 7 },
        "rustc": { "type": "string", "minLength": 1 },
        "cargo": { "type": "string", "minLength": 1 },
        "solana": { "type": "string", "minLength": 1 },
        "quasar": { "type": "string", "minLength": 1 },
        "init_command": { "type": "string", "minLength": 1 },
        "build_command": { "type": "string", "minLength": 1 },
        "test_command": { "type": "string", "minLength": 1 },
        "build_status": { "type": "string", "minLength": 1 },
        "test_status": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner", "reason", "expires_at", "reviewer_or_human_gate_ref", "compensating_controls", "evidence_refs"],
        "properties": {
          "owner": { "type": "string", "minLength": 2 },
          "reason": { "type": "string", "minLength": 3 },
          "expires_at": { "type": "string", "minLength": 10 },
          "reviewer_or_human_gate_ref": { "type": "string", "minLength": 3 },
          "compensating_controls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
