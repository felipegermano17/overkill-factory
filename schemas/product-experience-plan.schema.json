{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-experience-plan.schema.json",
  "title": "Overkill Factory Product Experience Plan",
  "type": "object",
  "required": [
    "surface_type",
    "surface_pack",
    "experience_sot",
    "user",
    "job_to_be_done",
    "main_flows",
    "required_states",
    "design_direction",
    "visual_quality_bar",
    "proof_required",
    "reviewers_required",
    "done_definition",
    "human_gate",
    "prototype_decision",
    "device_or_viewport_scope",
    "accessibility_scope",
    "performance_scope",
    "data_context",
    "docs_onboarding",
    "experience_qa",
    "product_face_result_required"
  ],
  "properties": {
    "surface_type": {
      "type": "string",
      "minLength": 2
    },
    "surface_pack": {
      "type": "string",
      "minLength": 2
    },
    "states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "user": {
      "type": "string",
      "minLength": 3
    },
    "job_to_be_done": {
      "type": "string",
      "minLength": 3
    },
    "main_flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "design_direction": {
      "type": "object",
      "required": ["visual_tone", "product_fit", "density", "interaction_style"],
      "properties": {
        "visual_tone": { "type": "string", "minLength": 3 },
        "product_fit": { "type": "string", "minLength": 3 },
        "density": { "type": "string", "minLength": 3 },
        "interaction_style": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "visual_quality_bar": {
      "type": "object",
      "required": ["reference_quality_bar", "anti_generic_criteria", "professional_review_required", "block_when"],
      "properties": {
        "reference_quality_bar": { "type": "string", "minLength": 3 },
        "anti_generic_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "professional_review_required": { "type": "boolean" },
        "block_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "proof_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessibility_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "experience_sot": {
      "type": "string",
      "minLength": 3
    },
    "prototype_decision": {
      "type": "string",
      "minLength": 3
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "device_or_viewport_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accessibility_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "performance_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "data_context": {
      "type": "string",
      "minLength": 3
    },
    "docs_onboarding": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "experience_qa": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "product_face_result_required": {
      "type": "boolean"
    },
    "reviewer_roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewers_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "done_definition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_gate": {
      "type": "object",
      "required": ["required", "reason"],
      "properties": {
        "required": { "type": "boolean" },
        "approver": { "type": "string" },
        "reason": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
