{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/gate-report.schema.json",
  "title": "Overkill Factory Gate Report",
  "type": "object",
  "required": [
    "report_type",
    "created_at",
    "card_id",
    "risk_effective",
    "surfaces",
    "gate_status",
    "required_workers",
    "blocked_workers",
    "card_validation_errors",
    "workers"
  ],
  "properties": {
    "report_type": {
      "const": "factory_gate_preflight"
    },
    "gate_status": {
      "enum": ["blocked", "ready_for_worker_execution", "pass_no_workers_required"]
    },
    "required_workers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocked_workers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "card_validation_errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["required", "reason", "status"],
        "additionalProperties": true
      }
    },
    "blocker_economics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "blocker_id",
          "owner",
          "risk_controlled",
          "cost_time_class",
          "dependency",
          "smallest_safe_next_action",
          "mutation_risk",
          "route",
          "expiry",
          "status"
        ],
        "properties": {
          "blocker_id": { "type": "string", "minLength": 3 },
          "owner": { "type": "string", "minLength": 2 },
          "risk_controlled": { "type": "string", "minLength": 3 },
          "cost_time_class": { "type": "string", "minLength": 3 },
          "dependency": { "type": "string", "minLength": 1 },
          "smallest_safe_next_action": { "type": "string", "minLength": 3 },
          "mutation_risk": { "type": "string", "minLength": 3 },
          "route": { "enum": ["local", "hermes", "github", "human_approval", "must_not_proceed"] },
          "expiry": { "type": "string", "minLength": 3 },
          "status": { "enum": ["blocked", "actionable", "deferred"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
