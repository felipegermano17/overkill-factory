{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-implementation-readiness.schema.json",
  "title": "Overkill Factory Product Implementation Readiness",
  "type": "object",
  "required": [
    "record_type",
    "product_sot_ref",
    "method_contract_ref",
    "product_creation_plan_ref",
    "artifact_alignment_result",
    "requirements_trace",
    "cross_slice_decision_coverage",
    "proof_coverage",
    "ready_work_units",
    "blocked_work_units",
    "allowed_next_actions",
    "forbidden_next_actions",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/product-implementation-readiness.schema.json" },
    "record_type": { "const": "product_implementation_readiness" },
    "product_sot_ref": { "type": "string", "minLength": 3 },
    "method_contract_ref": { "type": "string", "minLength": 3 },
    "product_creation_plan_ref": { "type": "string", "minLength": 3 },
    "artifact_alignment_result": { "enum": ["PASS", "CONCERNS", "FAIL", "BLOCKED"] },
    "requirements_trace": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "cross_slice_decision_coverage": { "type": "array", "items": { "type": "string" } },
    "experience_trace": { "type": "array", "items": { "type": "string" } },
    "security_trace": { "type": "array", "items": { "type": "string" } },
    "capability_pack_trace": { "type": "array", "items": { "type": "string" } },
    "access_and_secret_trace": { "type": "array", "items": { "type": "string" } },
    "proof_coverage": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "stale_artifacts": { "type": "array", "items": { "type": "string" } },
    "contradictions": { "type": "array", "items": { "type": "string" } },
    "ready_work_units": { "type": "array", "items": { "type": "string" } },
    "blocked_work_units": { "type": "array", "items": { "type": "string" } },
    "human_decisions_required": { "type": "array", "items": { "type": "string" } },
    "allowed_next_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "forbidden_next_actions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": true
}
