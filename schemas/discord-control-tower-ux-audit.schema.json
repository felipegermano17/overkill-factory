{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/discord-control-tower-ux-audit.schema.json",
  "title": "Overkill Factory Discord Control Tower UX Audit",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "scope",
    "observed_model",
    "checks",
    "findings",
    "live_corrections",
    "next_required_actions",
    "evidence_refs"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/discord-control-tower-ux-audit.schema.json"
    },
    "record_type": {
      "const": "discord_control_tower_ux_audit"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "ATTENTION", "BLOCKED"]
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "observed_model": {
      "type": "object",
      "required": [
        "runtime",
        "owner_language",
        "source_of_truth",
        "discord_role"
      ],
      "properties": {
        "runtime": { "type": "string", "minLength": 3 },
        "owner_language": { "type": "string", "minLength": 2 },
        "source_of_truth": { "type": "string", "minLength": 3 },
        "discord_role": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "object",
      "required": [
        "portuguese_first_structure",
        "operator_journey_categories_ordered",
        "channel_names_are_owner_readable",
        "single_owner_intake_door",
        "global_portfolio_view_defined",
        "project_index_not_detail_dump",
        "main_dashboard_pinned",
        "per_channel_onboarding_pinned",
        "gerente_channel_exists",
        "project_registry_channel_exists",
        "kanban_forum_exists",
        "kanban_forum_has_phase_tags",
        "kanban_forum_has_guidance_tags",
        "multi_project_kanban_shape_ready",
        "multi_project_kanban_idempotence_automated",
        "project_cockpit_pipeline_panel_required",
        "pilot_project_cockpit_pipeline_panel_created",
        "project_pipeline_progress_visible",
        "project_pipeline_projection_automated",
        "approval_lane_guided",
        "access_lane_guided",
        "blocker_lane_guided",
        "evidence_lane_guided",
        "release_lane_guided",
        "health_lane_guided",
        "pilot_project_thread_created",
        "pilot_forum_card_created",
        "kanban_guide_not_marked_as_blocked_project",
        "active_bot_messages_threaded_or_linked",
        "free_response_threading_conflict_documented",
        "manager_reception_thread_launcher_only",
        "project_conversation_stays_in_single_thread",
        "thread_first_project_intake_automated",
        "formal_approvals_lane_bound",
        "structured_approval_interactions_automated",
        "live_runtime_projection_automated"
      ],
      "properties": {
        "portuguese_first_structure": { "type": "boolean" },
        "operator_journey_categories_ordered": { "type": "boolean" },
        "channel_names_are_owner_readable": { "type": "boolean" },
        "single_owner_intake_door": { "type": "boolean" },
        "global_portfolio_view_defined": { "type": "boolean" },
        "project_index_not_detail_dump": { "type": "boolean" },
        "main_dashboard_pinned": { "type": "boolean" },
        "per_channel_onboarding_pinned": { "type": "boolean" },
        "gerente_channel_exists": { "type": "boolean" },
        "project_registry_channel_exists": { "type": "boolean" },
        "kanban_forum_exists": { "type": "boolean" },
        "kanban_forum_has_phase_tags": { "type": "boolean" },
        "kanban_forum_has_guidance_tags": { "type": "boolean" },
        "multi_project_kanban_shape_ready": { "type": "boolean" },
        "multi_project_kanban_idempotence_automated": { "type": "boolean" },
        "project_cockpit_pipeline_panel_required": { "type": "boolean" },
        "pilot_project_cockpit_pipeline_panel_created": { "type": "boolean" },
        "project_pipeline_progress_visible": { "type": "boolean" },
        "project_pipeline_projection_automated": { "type": "boolean" },
        "approval_lane_guided": { "type": "boolean" },
        "access_lane_guided": { "type": "boolean" },
        "blocker_lane_guided": { "type": "boolean" },
        "evidence_lane_guided": { "type": "boolean" },
        "release_lane_guided": { "type": "boolean" },
        "health_lane_guided": { "type": "boolean" },
        "pilot_project_thread_created": { "type": "boolean" },
        "pilot_forum_card_created": { "type": "boolean" },
        "kanban_guide_not_marked_as_blocked_project": { "type": "boolean" },
        "active_bot_messages_threaded_or_linked": { "type": "boolean" },
        "free_response_threading_conflict_documented": { "type": "boolean" },
        "manager_reception_thread_launcher_only": { "type": "boolean" },
        "project_conversation_stays_in_single_thread": { "type": "boolean" },
        "thread_first_project_intake_automated": { "type": "boolean" },
        "formal_approvals_lane_bound": { "type": "boolean" },
        "structured_approval_interactions_automated": { "type": "boolean" },
        "live_runtime_projection_automated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["severity", "finding", "impact", "required_fix"],
        "properties": {
          "severity": { "enum": ["P0", "P1", "P2", "P3"] },
          "finding": { "type": "string", "minLength": 3 },
          "impact": { "type": "string", "minLength": 3 },
          "required_fix": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "live_corrections": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "next_required_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}
