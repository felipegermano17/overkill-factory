{
  "$id": "https://overkill-factory.dev/schemas/hermes-real-runtime-smoke.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "smoke_type",
    "scope",
    "environment_ref",
    "checks",
    "cleanup",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/hermes-real-runtime-smoke.schema.json"
    },
    "record_type": {
      "const": "hermes_real_runtime_smoke"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "enum": [
        "PASS",
        "BLOCKED",
        "FAIL"
      ]
    },
    "smoke_type": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "environment_ref": {
      "type": "string",
      "minLength": 3
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "cleanup": {
      "type": "object",
      "required": [
        "method",
        "result"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 3
        },
        "result": {
          "enum": [
            "PASS",
            "BLOCKED",
            "FAIL"
          ]
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
