{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/agent-runtime-hardening-profile.schema.json",
  "title": "Overkill Factory Agent Runtime Hardening Profile",
  "type": "object",
  "required": [
    "record_type",
    "worker_id",
    "runtime_kind",
    "execution_mode",
    "tool_surface",
    "filesystem_scope",
    "network_scope",
    "credential_exposure",
    "secret_delivery_policy_ref",
    "side_effect_policy",
    "sandbox_boundary",
    "identity_boundary",
    "resource_limits",
    "log_policy",
    "egress_policy",
    "mutation_policy",
    "rollback_or_kill_switch",
    "human_gate_triggers",
    "validation_commands",
    "blocked_abuse_evidence_refs",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 10 },
    "record_type": { "const": "agent_runtime_hardening_profile" },
    "worker_id": { "type": "string", "minLength": 3 },
    "runtime_kind": {
      "enum": ["host_process", "container", "vm", "remote_runner", "hermes_profile", "browser_session", "mcp_server", "other"]
    },
    "execution_mode": {
      "enum": ["planning_only", "read_only", "bounded_execution", "material_execution", "production_operation"]
    },
    "tool_surface": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "filesystem_scope": {
      "enum": ["none", "repo_readonly", "repo_write", "path_allowlist", "workspace_wide", "external_mount"]
    },
    "network_scope": {
      "enum": ["none", "localhost_only", "allowlisted_egress", "vpn_only", "unrestricted"]
    },
    "credential_exposure": {
      "enum": ["none", "placeholder", "startup_env", "runtime_file", "jit_broker", "hardware_signer", "external_service"]
    },
    "secret_delivery_policy_ref": { "type": "string", "minLength": 3 },
    "side_effect_policy": { "enum": ["none", "dry_run_only", "approval_required", "bounded", "production_allowed"] },
    "sandbox_boundary": {
      "enum": ["none", "process_user", "container", "vm", "remote_clean_runner", "dedicated_host"]
    },
    "identity_boundary": { "type": "string", "minLength": 3 },
    "resource_limits": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "log_policy": { "type": "string", "minLength": 3 },
    "egress_policy": { "type": "string", "minLength": 3 },
    "mutation_policy": { "type": "string", "minLength": 3 },
    "rollback_or_kill_switch": { "type": "string", "minLength": 3 },
    "human_gate_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "blocked_abuse_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": false
}
