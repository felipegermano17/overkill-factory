{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/approval-request.schema.json",
  "title": "Overkill Factory Approval Request",
  "type": "object",
  "required": [
    "$schema",
    "approval_id",
    "project_id",
    "approval_type",
    "status",
    "risk",
    "scope",
    "requested_by",
    "created_at"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/approval-request.schema.json"
    },
    "approval_id": { "type": "string", "minLength": 3 },
    "project_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string" },
    "approval_type": {
      "type": "string",
      "enum": ["understanding", "plan", "access", "budget", "risk", "scope_change", "release", "production"]
    },
    "status": { "type": "string", "enum": ["pending", "approved", "rejected", "needs_changes", "expired"] },
    "risk": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "scope": { "type": "string", "minLength": 3 },
    "consequence": { "type": "string" },
    "not_authorized": { "type": "array", "items": { "type": "string" } },
    "requested_by": { "type": "string", "minLength": 1 },
    "decided_by": { "type": "string" },
    "decision_event_ref": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "expires_at": { "type": "string" },
    "created_at": { "type": "string", "minLength": 10 }
  },
  "additionalProperties": true
}
