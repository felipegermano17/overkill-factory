{
  "$id": "https://overkill-factory.dev/schemas/operator-control-tower-private-evidence-doctor.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "summary",
    "scope",
    "environment_ref",
    "evidence_refs",
    "limits",
    "decision",
    "checks",
    "blocking_items",
    "input_errors"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/operator-control-tower-private-evidence-doctor.schema.json"
    },
    "record_type": {
      "const": "operator_control_tower_private_evidence_doctor"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "BLOCKED", "FAIL"]
    },
    "summary": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "environment_ref": {
      "type": "string",
      "minLength": 3
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "operator_control_tower_production_proof_input",
        "next_required_action"
      ],
      "properties": {
        "operator_control_tower_production_proof_input": {
          "enum": ["ready", "blocked"]
        },
        "next_required_action": {
          "enum": [
            "run_operator_control_tower_proof",
            "collect_or_fix_private_control_tower_evidence"
          ]
        }
      },
      "additionalProperties": true
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "blocking_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
