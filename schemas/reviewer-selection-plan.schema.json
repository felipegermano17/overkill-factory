{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/reviewer-selection-plan.schema.json",
  "title": "Overkill Factory Reviewer Selection Plan",
  "type": "object",
  "required": [
    "record_type",
    "changed_surfaces",
    "risk_effective",
    "executor_identity",
    "forbidden_reviewers",
    "required_reviewers",
    "reviewer_matrix",
    "selection_rule",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 10 },
    "record_type": { "const": "reviewer_selection_plan" },
    "changed_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "risk_effective": { "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "executor_identity": { "type": "string", "minLength": 3 },
    "forbidden_reviewers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "required_reviewers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "reviewer_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["reviewer_worker", "covers", "reason", "mandatory"],
        "properties": {
          "reviewer_worker": { "type": "string", "minLength": 3 },
          "covers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 2 }
          },
          "reason": { "type": "string", "minLength": 8 },
          "mandatory": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "selection_rule": { "type": "string", "minLength": 12 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": false
}
