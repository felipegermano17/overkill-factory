{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/capability-pack-registry.schema.json",
  "title": "Overkill Factory Capability Pack Registry",
  "type": "object",
  "required": ["record_type", "version", "packs", "global_rules"],
  "properties": {
    "$schema": { "type": "string", "minLength": 10 },
    "record_type": { "const": "capability_pack_registry" },
    "version": { "type": "string", "minLength": 3 },
    "global_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 }
    },
    "packs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "pack_id",
          "status",
          "plain_purpose",
          "covers_surfaces",
          "existing_workers",
          "missing_worker_templates",
          "required_before_execution",
          "activation_rule",
          "evidence_required",
          "reference_sources"
        ],
        "properties": {
          "pack_id": { "type": "string", "minLength": 3 },
          "status": {
            "enum": ["core_ready", "pack_ready", "pack_template", "blocked_until_installed"]
          },
          "plain_purpose": { "type": "string", "minLength": 12 },
          "covers_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 2 }
          },
          "existing_workers": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 }
          },
          "missing_worker_templates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["worker_id", "why_needed", "promotion_condition"],
              "properties": {
                "worker_id": { "type": "string", "minLength": 3 },
                "why_needed": { "type": "string", "minLength": 12 },
                "promotion_condition": { "type": "string", "minLength": 12 }
              },
              "additionalProperties": false
            }
          },
          "required_before_execution": { "type": "boolean" },
          "activation_rule": { "type": "string", "minLength": 12 },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          },
          "reference_sources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
