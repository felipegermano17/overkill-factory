{
  "$id": "https://overkill-factory.dev/schemas/hermes-production-update-preflight.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "target",
    "result",
    "required_proofs",
    "blocking_items",
    "decision",
    "evidence_refs",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/hermes-production-update-preflight.schema.json"
    },
    "record_type": {
      "const": "hermes_production_update_preflight"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "const": "real-hermes-runtime-update"
    },
    "result": {
      "enum": [
        "PASS",
        "BLOCKED"
      ]
    },
    "required_proofs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "proof_ref",
          "description",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "PASS",
              "BLOCKED"
            ]
          },
          "proof_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "blocking_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "object",
      "required": [
        "real_runtime_update",
        "worker_task_status"
      ],
      "properties": {
        "real_runtime_update": {
          "enum": [
            "allowed_for_explicit_operator_gate",
            "blocked"
          ]
        },
        "worker_task_status": {
          "enum": [
            "ready_requires_operator_gate",
            "keep_blocked"
          ]
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
