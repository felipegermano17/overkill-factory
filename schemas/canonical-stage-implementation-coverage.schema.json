{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/canonical-stage-implementation-coverage.schema.json",
  "title": "Overkill Factory Canonical Stage Implementation Coverage",
  "type": "object",
  "required": ["record_type", "canonical_doc_ref", "coverage_rule", "stages"],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/canonical-stage-implementation-coverage.schema.json"
    },
    "record_type": {
      "const": "canonical_stage_implementation_coverage"
    },
    "canonical_doc_ref": {
      "type": "string",
      "minLength": 3
    },
    "coverage_rule": {
      "type": "string",
      "minLength": 10
    },
    "stages": {
      "type": "array",
      "minItems": 32,
      "items": {
        "type": "object",
        "required": [
          "stage_number",
          "stage_name",
          "canonical_promises",
          "implementation_refs",
          "coverage_status"
        ],
        "properties": {
          "stage_number": {
            "type": "integer"
          },
          "stage_name": {
            "type": "string",
            "minLength": 3
          },
          "canonical_promises": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "implementation_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "path", "covers"],
              "properties": {
                "kind": {
                  "enum": [
                    "schema",
                    "template",
                    "script",
                    "test",
                    "worker_registry",
                    "worker_profile",
                    "profile_binding",
                    "validation_artifact",
                    "runtime_adapter",
                    "documentation"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 3
                },
                "covers": {
                  "type": "string",
                  "minLength": 3
                }
              },
              "additionalProperties": false
            }
          },
          "coverage_status": {
            "enum": ["implemented_by_contract", "implemented_by_runtime", "bounded_public_proof"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
