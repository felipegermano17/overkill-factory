{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/factory-improvement-radar.schema.json",
  "title": "Factory Improvement Radar",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "cadence",
    "source_watchlist",
    "signals",
    "human_approval_boundary"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/factory-improvement-radar.schema.json"
    },
    "record_type": { "const": "factory_improvement_radar" },
    "cadence": {
      "enum": [
        "event_driven",
        "daily",
        "weekly",
        "pre_release",
        "manual"
      ]
    },
    "source_watchlist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_type", "source_ref", "purpose"],
        "properties": {
          "source_type": {
            "enum": [
              "hermes_release",
              "hermes_runtime",
              "execution_history",
              "worker_feedback",
              "github_repo",
              "dependency",
              "external_research",
              "support_signal"
            ]
          },
          "source_ref": { "type": "string", "minLength": 3 },
          "purpose": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_type",
          "public_safe_summary",
          "benefit_hypothesis",
          "risk",
          "recommended_action",
          "validation_expected",
          "raw_evidence_included"
        ],
        "properties": {
          "source_type": {
            "enum": [
              "hermes_release",
              "hermes_runtime",
              "execution_history",
              "worker_feedback",
              "github_repo",
              "dependency",
              "external_research",
              "support_signal"
            ]
          },
          "source_ref": { "type": "string" },
          "public_safe_summary": { "type": "string", "minLength": 3 },
          "benefit_hypothesis": { "type": "string", "minLength": 3 },
          "risk": { "type": "string", "minLength": 3 },
          "recommended_action": {
            "enum": [
              "create_issue",
              "reject",
              "monitor",
              "request_human_decision"
            ]
          },
          "validation_expected": { "type": "string", "minLength": 3 },
          "raw_evidence_included": { "const": false }
        },
        "additionalProperties": false
      }
    },
    "issues_to_create": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejections": {
      "type": "array",
      "items": { "type": "string" }
    },
    "human_approval_boundary": {
      "type": "string",
      "minLength": 3
    }
  },
  "additionalProperties": false
}
