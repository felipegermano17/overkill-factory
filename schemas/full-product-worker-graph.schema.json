{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/full-product-worker-graph.schema.json",
  "title": "Overkill Factory Full Product Worker Graph",
  "type": "object",
  "required": [
    "record_type",
    "created_at",
    "graph_kind",
    "product_id",
    "result",
    "blocking_findings",
    "evidence_kind",
    "reusable_for_product",
    "completion_claim_allowed",
    "lanes_total",
    "lanes_passed",
    "lanes",
    "blocking_summary",
    "production_blockers",
    "evidence_refs",
    "policy_decision",
    "next_action"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 10
    },
    "record_type": {
      "const": "full_product_worker_graph"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "graph_kind": {
      "type": "string",
      "minLength": 3
    },
    "product_id": {
      "type": "string",
      "minLength": 3
    },
    "product_name": {
      "type": "string"
    },
    "product_target": {
      "type": "object"
    },
    "result": {
      "enum": ["PASS", "FAIL"]
    },
    "blocking_findings": {
      "type": "boolean"
    },
    "evidence_kind": {
      "enum": ["real", "synthetic", "waiver"]
    },
    "reusable_for_product": {
      "type": "boolean"
    },
    "completion_claim_allowed": {
      "type": "boolean"
    },
    "lanes_total": {
      "type": "integer"
    },
    "lanes_passed": {
      "type": "integer"
    },
    "product_lanes_total": {
      "type": "integer"
    },
    "supporting_lanes_total": {
      "type": "integer"
    },
    "reusable_for_product_lanes": {
      "type": "integer"
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lane_id",
          "scope",
          "evidence_ref",
          "status",
          "validation_errors",
          "reusable_for_product"
        ],
        "properties": {
          "lane_id": {
            "type": "string",
            "minLength": 2
          },
          "scope": {
            "enum": ["product", "supporting"]
          },
          "worker_id": {
            "type": ["string", "null"]
          },
          "record_type": {
            "type": ["string", "null"]
          },
          "proof_kind": {
            "type": ["string", "null"]
          },
          "receipt_type": {
            "type": ["string", "null"]
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 3
          },
          "card_id": {
            "type": "string"
          },
          "result": {
            "type": ["string", "null"]
          },
          "evidence_kind": {
            "type": "string"
          },
          "reusable_for_product": {
            "type": "boolean"
          },
          "evidence_ref_count": {
            "type": "integer"
          },
          "stale_evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "enum": ["PASS", "FAIL"]
          },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "blocking_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "production_blockers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "policy_decision": {
      "type": "string",
      "minLength": 3
    },
    "next_action": {
      "type": "string",
      "minLength": 3
    }
  },
  "additionalProperties": false
}
