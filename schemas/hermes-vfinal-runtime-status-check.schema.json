{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/hermes-vfinal-runtime-status-check.schema.json",
  "title": "Overkill Factory vFinal Hermes Runtime Status Check",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "scope",
    "checks",
    "evidence_refs",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/hermes-vfinal-runtime-status-check.schema.json"
    },
    "record_type": {
      "const": "hermes_vfinal_runtime_status_check"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "ATTENTION", "BLOCKED"]
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "checks": {
      "type": "object",
      "required": [
        "hermes_status_readonly_passed",
        "profile_list_readonly_passed",
        "gateway_service_running",
        "discord_configured",
        "dedicated_gerente_gateway_running",
        "private_product_profile_not_factory_gateway",
        "factory_worker_profiles_present",
        "raw_private_values_omitted"
      ],
      "properties": {
        "hermes_status_readonly_passed": { "type": "boolean" },
        "profile_list_readonly_passed": { "type": "boolean" },
        "gateway_service_running": { "type": "boolean" },
        "discord_configured": { "type": "boolean" },
        "dedicated_gerente_gateway_running": { "type": "boolean" },
        "private_product_profile_not_factory_gateway": { "type": "boolean" },
        "factory_worker_profiles_present": { "type": "boolean" },
        "raw_private_values_omitted": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}
