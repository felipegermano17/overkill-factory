{
  "$id": "https://overkill-factory.dev/schemas/factory-vfinal-provider-model-audit.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "scope",
    "runtime_ref",
    "profile_registry_ref",
    "profile_contract_ref",
    "binding_registry_ref",
    "canonical_provider",
    "canonical_model_ref",
    "counts",
    "checks",
    "evidence_refs",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/factory-vfinal-provider-model-audit.schema.json"
    },
    "record_type": {
      "const": "factory_vfinal_provider_model_audit"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "enum": ["PASS", "BLOCKED"]
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "runtime_ref": {
      "type": "string",
      "minLength": 3
    },
    "profile_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "profile_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "binding_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "canonical_provider": {
      "type": "string",
      "minLength": 1
    },
    "canonical_model_ref": {
      "type": "string",
      "minLength": 1
    },
    "counts": {
      "type": "object",
      "required": [
        "public_worker_profiles",
        "dedicated_gateway_profiles",
        "factory_scope_profiles_checked",
        "hermes_profiles_total_observed",
        "public_workers_missing_in_hermes",
        "factory_scope_provider_model_mismatch",
        "factory_scope_missing_auth",
        "factory_scope_missing_env",
        "extra_hermes_profiles_outside_public_registry"
      ],
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "factory_scope_missing_env_profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missing_env_interpretation": {
      "type": "string"
    },
    "non_factory_provider_model_exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["profile_ref", "provider", "model_ref", "status"],
        "properties": {
          "profile_ref": { "type": "string", "minLength": 1 },
          "provider": { "type": "string", "minLength": 1 },
          "model_ref": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
