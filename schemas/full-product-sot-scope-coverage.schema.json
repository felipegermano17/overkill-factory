{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/full-product-sot-scope-coverage.schema.json",
  "title": "Overkill Factory Full Product SOT Scope Coverage",
  "type": "object",
  "required": [
    "record_type",
    "product_sot_ref",
    "coverage_policy",
    "source_claim_resolution",
    "requirement_coverage",
    "slice_policy",
    "completion_rule",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/full-product-sot-scope-coverage.schema.json" },
    "record_type": { "const": "full_product_sot_scope_coverage" },
    "product_sot_ref": { "type": "string", "minLength": 3 },
    "coverage_policy": {
      "type": "string",
      "minLength": 12
    },
    "source_claim_resolution": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_ref", "disposition", "rationale", "authority_ref"],
        "properties": {
          "claim_ref": { "type": "string", "minLength": 3 },
          "disposition": {
            "enum": ["promoted", "changed", "rejected", "deferred", "assumption", "open"]
          },
          "rationale": { "type": "string", "minLength": 3 },
          "authority_ref": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": true
      }
    },
    "requirement_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["requirement_ref", "status", "owner", "evidence_refs"],
        "properties": {
          "requirement_ref": { "type": "string", "minLength": 3 },
          "status": {
            "enum": ["planned", "blocked", "deferred_with_owner", "out_of_scope", "done", "human_decision_required"]
          },
          "owner": { "type": "string", "minLength": 3 },
          "work_unit_refs": { "type": "array", "items": { "type": "string" } },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "slice_policy": {
      "type": "object",
      "required": ["scope_reduction_forbidden", "slices_are_order_only"],
      "properties": {
        "scope_reduction_forbidden": { "const": true },
        "slices_are_order_only": { "const": true },
        "waiver_required_for_defer": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "completion_rule": { "type": "string", "minLength": 12 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": true
}
