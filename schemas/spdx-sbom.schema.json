{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/spdx-sbom.schema.json",
  "title": "Overkill Factory SPDX Source SBOM",
  "type": "object",
  "required": [
    "spdxVersion",
    "dataLicense",
    "SPDXID",
    "name",
    "documentNamespace",
    "creationInfo",
    "packages",
    "files"
  ],
  "properties": {
    "spdxVersion": {
      "const": "SPDX-2.3"
    },
    "dataLicense": {
      "type": "string",
      "minLength": 3
    },
    "SPDXID": {
      "const": "SPDXRef-DOCUMENT"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "documentNamespace": {
      "type": "string",
      "minLength": 10
    },
    "creationInfo": {
      "type": "object",
      "required": ["created", "creators"],
      "properties": {
        "created": {
          "type": "string",
          "minLength": 10
        },
        "creators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      },
      "additionalProperties": true
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["SPDXID", "name", "filesAnalyzed", "packageVerificationCode"],
        "properties": {
          "SPDXID": {
            "type": "string",
            "minLength": 3
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "filesAnalyzed": {
            "type": "boolean"
          },
          "packageVerificationCode": {
            "type": "object",
            "required": ["packageVerificationCodeValue"],
            "properties": {
              "packageVerificationCodeValue": {
                "type": "string",
                "minLength": 64
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["SPDXID", "fileName", "checksums"],
        "properties": {
          "SPDXID": {
            "type": "string",
            "minLength": 3
          },
          "fileName": {
            "type": "string",
            "minLength": 1
          },
          "checksums": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["algorithm", "checksumValue"],
              "properties": {
                "algorithm": {
                  "const": "SHA256"
                },
                "checksumValue": {
                  "type": "string",
                  "minLength": 64
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
