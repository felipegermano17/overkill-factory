{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/quasar-cu-svm-economic-proof.schema.json",
  "title": "Overkill Factory Quasar CU/SVM/Economic Proof",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "result",
    "proof_kind",
    "created_at",
    "source_target",
    "source_sha256",
    "runtime_proof_ref",
    "product_target",
    "property_fuzz_coverage",
    "compute_unit_profile",
    "svm_or_client_flow_coverage",
    "negative_case_coverage",
    "economic_safety",
    "evidence_refs",
    "evidence_kind",
    "reusable_for_product",
    "blocking_findings",
    "policy_decision"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/quasar-cu-svm-economic-proof.schema.json"
    },
    "record_type": {
      "const": "cu_svm_economic_proof"
    },
    "result": {
      "enum": ["PASS", "FAIL"]
    },
    "proof_kind": {
      "const": "production_quasar_cu_svm_economic"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "source_target": {
      "type": "string",
      "minLength": 3
    },
    "source_sha256": {
      "type": "string",
      "minLength": 64
    },
    "runtime_proof_ref": {
      "type": "string",
      "minLength": 3
    },
    "product_target": {
      "type": "object",
      "required": [
        "product_id",
        "environment_class",
        "source_ref",
        "source_sha256",
        "approval_scope"
      ],
      "properties": {
        "product_id": {
          "type": "string",
          "minLength": 3
        },
        "environment_class": {
          "enum": ["production-validation-quasar-svm", "production-quasar-svm"]
        },
        "source_ref": {
          "type": "string",
          "minLength": 3
        },
        "source_sha256": {
          "type": "string",
          "minLength": 64
        },
        "approval_scope": {
          "type": "string",
          "minLength": 10
        }
      },
      "additionalProperties": true
    },
    "property_fuzz_coverage": {
      "type": "object",
      "required": ["total_cases", "cases"],
      "properties": {
        "total_cases": {
          "type": "integer"
        },
        "cases": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "compute_unit_profile": {
      "type": "object",
      "required": [
        "profile_kind",
        "real_solana_cu_measured",
        "compute_budget_units",
        "instruction_profile"
      ],
      "properties": {
        "profile_kind": {
          "const": "runtime_svm_measurement"
        },
        "real_solana_cu_measured": {
          "const": true
        },
        "compute_budget_units": {
          "type": "integer"
        },
        "instruction_profile": {
          "type": "object",
          "minProperties": 1
        }
      },
      "additionalProperties": true
    },
    "svm_or_client_flow_coverage": {
      "type": "object",
      "required": ["quasar_test_passed", "flows", "real_svm_transaction_harness"],
      "properties": {
        "quasar_test_passed": {
          "const": true
        },
        "flows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object"
          }
        },
        "real_svm_transaction_harness": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "negative_case_coverage": {
      "type": "object",
      "minProperties": 1
    },
    "economic_safety": {
      "type": "object",
      "required": ["overall_verdict"],
      "properties": {
        "overall_verdict": {
          "enum": ["PASS", "FAIL"]
        }
      },
      "additionalProperties": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_kind": {
      "const": "real"
    },
    "reusable_for_product": {
      "const": true
    },
    "blocking_findings": {
      "type": "boolean"
    },
    "policy_decision": {
      "type": "string",
      "minLength": 3
    }
  },
  "additionalProperties": true
}
