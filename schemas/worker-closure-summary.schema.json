{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/worker-closure-summary.schema.json",
  "title": "Overkill Factory Worker Closure Summary",
  "type": "object",
  "required": ["record_type", "scope", "workers", "result"],
  "properties": {
    "record_type": { "const": "worker_closure_summary" },
    "scope": { "type": "string", "minLength": 3 },
    "workers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["required_by_gate_report", "result", "evidence_refs"],
        "properties": {
          "required_by_gate_report": { "type": "boolean" },
          "result": { "type": "string", "minLength": 3 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          }
        },
        "additionalProperties": true
      }
    },
    "result": { "type": "string", "minLength": 3 }
  },
  "additionalProperties": true
}
