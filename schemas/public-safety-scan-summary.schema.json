{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/public-safety-scan-summary.schema.json",
  "title": "Overkill Factory Public Safety Scan Summary",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "target",
    "result",
    "finding_count",
    "forbidden_hits",
    "categories",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/public-safety-scan-summary.schema.json"
    },
    "record_type": {
      "const": "public_safety_scan_summary"
    },
    "created_at": { "type": "string", "minLength": 10 },
    "target": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["worktree", "git_ref"] },
        "ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "result": { "enum": ["PASS", "FAIL"] },
    "finding_count": { "type": "integer" },
    "forbidden_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "count"],
        "properties": {
          "category": { "type": "string", "minLength": 1 },
          "count": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "count"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "count": { "type": "integer" }
        },
        "additionalProperties": false
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
