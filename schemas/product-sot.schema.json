{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-sot.schema.json",
  "title": "Overkill Factory Product SOT",
  "type": "object",
  "required": [
    "what_it_is",
    "target_users",
    "why_it_matters",
    "outcome",
    "scope_in",
    "scope_out",
    "risks",
    "authority",
    "data_and_metrics",
    "dependencies",
    "access_and_capabilities",
    "compliance_privacy",
    "cost_relevance",
    "operations_expected",
    "success_criteria",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/product-sot.schema.json" },
    "what_it_is": { "type": "string", "minLength": 3 },
    "target_users": { "type": "array", "items": { "type": "string" } },
    "why_it_matters": { "type": "string", "minLength": 3 },
    "outcome": { "type": "string", "minLength": 3 },
    "scope_in": { "type": "array", "items": { "type": "string" } },
    "scope_out": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "authority": { "type": "string", "minLength": 3 },
    "data_and_metrics": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "access_and_capabilities": { "type": "array", "items": { "type": "string" } },
    "compliance_privacy": { "type": "array", "items": { "type": "string" } },
    "cost_relevance": { "type": "string", "minLength": 3 },
    "operations_expected": { "type": "array", "items": { "type": "string" } },
    "success_criteria": { "type": "array", "items": { "type": "string" } },
    "open_decisions": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
