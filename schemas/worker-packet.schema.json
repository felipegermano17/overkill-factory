{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/worker-packet.schema.json",
  "title": "Overkill Factory Worker Packet",
  "type": "object",
  "required": [
    "packet_type",
    "created_at",
    "worker",
    "trigger",
    "card_ref",
    "input_contract",
    "output_contract",
    "profile_binding",
    "status"
  ],
  "properties": {
    "packet_type": {
      "const": "worker_execution_request"
    },
    "worker": {
      "type": "object",
      "required": [
        "id",
        "name",
        "factory_phase",
        "tool_required"
      ],
      "properties": {
        "id": {
          "enum": [
            "codex-security",
            "solana-quasar-auditor",
            "product-face",
            "independent-reviewer",
            "evidence-reconciler",
            "human-gate-clerk",
            "factory-orchestrator",
            "source-ledger-worker",
            "product-sot-planner",
            "product-architect",
            "docs-os-worker",
            "decomposition-planner",
            "implementation-worker",
            "qa-verification-worker",
            "autoreview-gate",
            "security-orchestrator",
            "appsec-owasp-specialist",
            "agentic-ai-security-specialist",
            "cloud-infra-security-specialist",
            "crypto-key-management-specialist",
            "remote-proof-runner",
            "release-ops-worker",
            "handoff-packer",
            "memory-steward",
            "skill-eval-distiller",
            "public-safety-gate",
            "supply-chain-gate",
            "detection-monitoring-worker",
            "frontend-builder",
            "backend-api-builder",
            "data-persistence-builder",
            "solana-quasar-builder",
            "solana-quasar-qa-engineer",
            "wallet-transaction-builder",
            "integration-builder",
            "test-automation-builder",
            "infra-devops-builder",
            "agent-runtime-builder",
            "control-tower-projection-worker",
            "discord-control-tower-bridge"
          ]
        }
      },
      "additionalProperties": true
    },
    "trigger": {
      "type": "object",
      "required": [
        "required",
        "reason",
        "timing",
        "blocking_policy"
      ],
      "additionalProperties": true
    },
    "card_ref": {
      "type": "object",
      "required": [
        "card_id",
        "slice_id",
        "phase",
        "risk_effective",
        "surfaces"
      ],
      "additionalProperties": true
    },
    "input_contract": {
      "type": "object",
      "required": [
        "required_fields",
        "missing_fields",
        "authority_max",
        "forbidden_actions"
      ],
      "additionalProperties": true
    },
    "output_contract": {
      "type": "object",
      "required": [
        "receipt_field",
        "must_attach_artifact_refs",
        "must_state_blocking_findings",
        "must_record_tool_or_profile"
      ],
      "additionalProperties": true
    },
    "profile_binding": {
      "type": "object",
      "required": [
        "profile_id",
        "hermes_profile_name",
        "dispatch_queue_policy",
        "queue_class_source",
        "skill_refs",
        "result_schema",
        "receipt_field",
        "can_mutate_card_state",
        "evidence_path_policy",
        "profile_manifest_ref",
        "profile_description_ref",
        "toolset_policy",
        "skill_install_ref",
        "last_hermes_smoke_ref"
      ],
      "properties": {
        "profile_id": {
          "type": "string",
          "minLength": 3
        },
        "hermes_profile_name": {
          "type": "string",
          "minLength": 3
        },
        "dispatch_queue_policy": {
          "type": "object",
          "required": [
            "source_of_truth",
            "default_queue",
            "allowed_effective_queues"
          ],
          "properties": {
            "source_of_truth": {
              "const": "factoryctl.worker_queue_class"
            },
            "default_queue": {
              "enum": [
                "blocking-before-ready",
                "blocking-before-done",
                "advisory-review",
                "human-gate"
              ]
            },
            "allowed_effective_queues": {
              "type": "array",
              "minItems": 1,
              "items": {
                "enum": [
                  "blocking-before-ready",
                  "blocking-before-done",
                  "advisory-review",
                  "human-gate"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "queue_class_source": {
          "const": "worker_task.queue_class"
        },
        "skill_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "result_schema": {
          "type": "string",
          "minLength": 3
        },
        "receipt_field": {
          "type": "string",
          "minLength": 3
        },
        "can_mutate_card_state": {
          "type": "boolean"
        },
        "evidence_path_policy": {
          "type": "string",
          "minLength": 12
        },
        "profile_manifest_ref": {
          "type": "string",
          "minLength": 3
        },
        "profile_description_ref": {
          "type": "string",
          "minLength": 3
        },
        "toolset_policy": {
          "type": "string",
          "minLength": 8
        },
        "skill_install_ref": {
          "type": "string",
          "minLength": 3
        },
        "last_hermes_smoke_ref": {
          "type": "string",
          "minLength": 3
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "requires_execution",
        "blocked_missing_inputs",
        "blocked_missing_profile_binding",
        "not_required_by_current_card"
      ]
    }
  },
  "additionalProperties": true
}
