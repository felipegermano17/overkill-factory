{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/project-projection.schema.json",
  "title": "Overkill Factory Project Projection",
  "type": "object",
  "required": [
    "$schema",
    "project_id",
    "name",
    "phase",
    "status",
    "execution_started",
    "risk",
    "forecast_confidence",
    "last_synced_at"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/project-projection.schema.json"
    },
    "project_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "intake",
        "planning",
        "waiting_owner",
        "waiting_access",
        "ready_to_execute",
        "executing",
        "review",
        "blocked",
        "release_candidate",
        "production",
        "closed"
      ]
    },
    "execution_started": { "type": "boolean" },
    "risk": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "forecast_confidence": { "type": "string", "enum": ["high", "medium", "low", "blocked"] },
    "current_blockers": { "type": "array", "items": { "type": "string" } },
    "pending_access": { "type": "array", "items": { "type": "string" } },
    "pending_approvals": { "type": "array", "items": { "type": "string" } },
    "next_steps": { "type": "array", "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "source_runtime": { "type": "string" },
    "source_board": { "type": "string" },
    "last_synced_at": { "type": "string", "minLength": 10 }
  },
  "additionalProperties": true
}
