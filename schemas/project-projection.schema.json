{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/project-projection.schema.json",
  "title": "Overkill Factory Project Projection",
  "type": "object",
  "required": [
    "$schema",
    "project_id",
    "name",
    "phase",
    "status",
    "execution_started",
    "risk",
    "forecast_confidence",
    "completion_percent",
    "pipeline_stages",
    "next_action",
    "projection_freshness",
    "last_synced_at",
    "planned_summary",
    "missing_items",
    "forecast_risks",
    "human_decisions_required",
    "truth_source_available"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/project-projection.schema.json"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "intake",
        "planning",
        "waiting_owner",
        "waiting_access",
        "ready_to_execute",
        "executing",
        "review",
        "blocked",
        "release_candidate",
        "production",
        "closed"
      ]
    },
    "execution_started": {
      "type": "boolean"
    },
    "risk": {
      "type": "string",
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "forecast_confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "blocked"
      ]
    },
    "completion_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "pipeline_stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["done", "current", "pending", "blocked", "skipped"]
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "projection_freshness": {
      "enum": ["runtime_fresh", "manual_estimate", "stale", "blocked"]
    },
    "current_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pending_access": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pending_approvals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_runtime": {
      "type": "string"
    },
    "source_board": {
      "type": "string"
    },
    "last_synced_at": {
      "type": "string",
      "minLength": 10
    },
    "planned_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forecast_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_decisions_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "truth_source_available": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
