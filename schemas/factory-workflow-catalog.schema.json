{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/factory-workflow-catalog.schema.json",
  "title": "Factory Workflow Catalog",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "factory_method_version",
    "catalog_version",
    "phases"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/factory-workflow-catalog.schema.json"
    },
    "record_type": { "const": "factory_workflow_catalog" },
    "factory_method_version": { "const": "OVERKILL_VFINAL" },
    "catalog_version": { "type": "string", "minLength": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "phase_id",
          "phase_name",
          "entry_conditions",
          "required_artifacts",
          "optional_artifacts",
          "required_gates",
          "required_workers",
          "allowed_next_actions",
          "blocked_actions",
          "output_locations",
          "completion_detection",
          "operator_visible_summary",
          "maintainer_visible_details",
          "related_schema_refs",
          "related_command_refs",
          "related_issue_refs"
        ],
        "properties": {
          "phase_id": { "type": "string", "minLength": 2 },
          "phase_name": { "type": "string", "minLength": 3 },
          "entry_conditions": { "type": "array", "items": { "type": "string" } },
          "required_artifacts": { "type": "array", "items": { "type": "string" } },
          "optional_artifacts": { "type": "array", "items": { "type": "string" } },
          "required_gates": { "type": "array", "items": { "type": "string" } },
          "required_workers": { "type": "array", "items": { "type": "string" } },
          "allowed_next_actions": { "type": "array", "items": { "type": "string" } },
          "blocked_actions": { "type": "array", "items": { "type": "string" } },
          "output_locations": { "type": "array", "items": { "type": "string" } },
          "completion_detection": { "type": "array", "items": { "type": "string" } },
          "operator_visible_summary": { "type": "string", "minLength": 3 },
          "maintainer_visible_details": { "type": "string", "minLength": 3 },
          "related_schema_refs": { "type": "array", "items": { "type": "string" } },
          "related_command_refs": { "type": "array", "items": { "type": "string" } },
          "related_issue_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
