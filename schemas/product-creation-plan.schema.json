{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-creation-plan.schema.json",
  "title": "Overkill Factory Product Creation Plan",
  "type": "object",
  "required": [
    "record_type",
    "product_sot_ref",
    "method_contract_ref",
    "complete_product_required",
    "complete_product_scope",
    "production_readiness_scope",
    "work_units",
    "execution_order",
    "slice_boundaries",
    "dependency_graph",
    "risk_map",
    "release_promotion_ladder_refs",
    "complete_product_done_criteria",
    "slice_done_criteria",
    "drift_check",
    "stop_conditions",
    "reconciliation_policy",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/product-creation-plan.schema.json" },
    "record_type": { "const": "product_creation_plan" },
    "product_sot_ref": { "type": "string", "minLength": 3 },
    "method_contract_ref": { "type": "string", "minLength": 3 },
    "research_decision_refs": { "type": "array", "items": { "type": "string" } },
    "architecture_decision_refs": { "type": "array", "items": { "type": "string" } },
    "complete_product_required": { "type": "boolean" },
    "complete_product_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "complete_product_non_goals": { "type": "array", "items": { "type": "string" } },
    "production_readiness_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "surface_matrix": { "type": "array", "items": { "type": "object" } },
    "capability_pack_requirements": { "type": "array", "items": { "type": "string" } },
    "work_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "product_sot_requirement_refs",
          "objective",
          "scope_in",
          "scope_out",
          "verification",
          "expected_result",
          "stop_conditions",
          "status"
        ],
        "properties": {
          "unit_id": { "type": "string", "minLength": 3 },
          "product_sot_requirement_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "objective": { "type": "string", "minLength": 8 },
          "scope_in": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "scope_out": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "verification": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "expected_result": { "type": "string", "minLength": 3 },
          "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "status": {
            "enum": ["todo", "ready", "blocked", "in_progress", "done", "rejected", "superseded", "needs_refresh"]
          },
          "product_context_packet_ref": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "execution_order": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "slice_boundaries": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "dependency_graph": { "type": "array", "items": { "type": "object" } },
    "risk_map": { "type": "array", "items": { "type": "string" } },
    "access_and_secret_requirements": { "type": "array", "items": { "type": "string" } },
    "release_promotion_ladder_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "complete_product_done_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "slice_done_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "drift_check": { "type": "string", "minLength": 8 },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "reconciliation_policy": { "type": "string", "minLength": 8 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": true
}
