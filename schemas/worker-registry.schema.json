{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/worker-registry.schema.json",
  "title": "Overkill Factory Worker Registry",
  "type": "object",
  "required": ["registry_version", "workers"],
  "properties": {
    "registry_version": { "type": "string", "minLength": 3 },
    "workers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "worker_id",
          "mode",
          "phase",
          "triggers",
          "inputs",
          "tools",
          "output_contract",
          "authority_max",
          "veto_conditions",
          "evidence_required",
          "kanban_transition_rules",
          "promotion_rule",
          "public_safety_notes"
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
