{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/secret-delivery-policy.schema.json",
  "title": "Overkill Factory Secret Delivery Policy",
  "type": "object",
  "required": [
    "record_type",
    "secret_type",
    "sensitivity",
    "environment",
    "delivery_mode",
    "scope",
    "ttl_or_expiry",
    "rotation_policy",
    "audit_log_ref",
    "redaction_policy",
    "revocation_path",
    "human_gate_required",
    "allowed_worker_ids",
    "forbidden_exposure",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 10 },
    "record_type": { "const": "secret_delivery_policy" },
    "secret_type": {
      "enum": [
        "api_key",
        "oauth_token",
        "cloud_credential",
        "database_credential",
        "signing_key",
        "wallet_key",
        "webhook_secret",
        "ssh_key",
        "deployment_token",
        "browser_session",
        "other"
      ]
    },
    "sensitivity": { "enum": ["public_test", "low", "moderate", "high", "critical"] },
    "environment": { "enum": ["local", "test", "devnet", "staging", "mainnet", "production"] },
    "delivery_mode": {
      "enum": [
        "none",
        "placeholder",
        "simulator",
        "user-mediated",
        "jit_broker",
        "vault_jit",
        "hardware_signer",
        "external_service",
        "startup_env",
        "runtime_file",
        "prompt_context"
      ]
    },
    "scope": { "type": "string", "minLength": 3 },
    "ttl_or_expiry": { "type": "string", "minLength": 3 },
    "rotation_policy": { "type": "string", "minLength": 3 },
    "audit_log_ref": { "type": "string", "minLength": 3 },
    "redaction_policy": { "type": "string", "minLength": 3 },
    "revocation_path": { "type": "string", "minLength": 3 },
    "human_gate_required": { "type": "boolean" },
    "allowed_worker_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "forbidden_exposure": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "human_gated_waiver": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
