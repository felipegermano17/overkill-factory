{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/prepilot-master-task-readiness.schema.json",
  "title": "Overkill Factory Prepilot Master Task Readiness",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "readiness_level",
    "source_plan",
    "coverage_rule",
    "tasks",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/prepilot-master-task-readiness.schema.json"
    },
    "record_type": {
      "const": "prepilot_master_task_readiness"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "ATTENTION", "BLOCKED"]
    },
    "readiness_level": {
      "enum": [
        "PASS_PREPILOT_READY_WITH_REDACTED_PRIVATE_PROOF",
        "ATTENTION_PUBLIC_CONTRACT_READY_PRIVATE_REVIEW_NEEDED",
        "BLOCKED"
      ]
    },
    "source_plan": {
      "type": "string",
      "minLength": 3
    },
    "coverage_rule": {
      "type": "string",
      "minLength": 10
    },
    "tasks": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "required": [
          "task_number",
          "task_id",
          "plain_goal",
          "status",
          "implementation_summary",
          "evidence_refs",
          "remaining_limit"
        ],
        "properties": {
          "task_number": {
            "type": "integer"
          },
          "task_id": {
            "type": "string",
            "minLength": 3
          },
          "plain_goal": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "enum": [
              "PASS_PUBLIC_CONTRACT",
              "PASS_PUBLIC_RUNTIME",
              "PASS_PRIVATE_PROOF_REDACTED",
              "PASS_VALIDATION_BATTERY",
              "ATTENTION",
              "BLOCKED"
            ]
          },
          "implementation_summary": {
            "type": "string",
            "minLength": 10
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "path", "covers"],
              "properties": {
                "kind": {
                  "enum": [
                    "schema",
                    "template",
                    "script",
                    "test",
                    "worker_registry",
                    "worker_profile",
                    "worker_roster",
                    "profile_binding",
                    "permission_matrix",
                    "validation_artifact",
                    "runtime_adapter",
                    "documentation"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 3
                },
                "covers": {
                  "type": "string",
                  "minLength": 3
                }
              },
              "additionalProperties": false
            }
          },
          "remaining_limit": {
            "type": "string",
            "minLength": 3
          }
        },
        "additionalProperties": false
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": false
}
