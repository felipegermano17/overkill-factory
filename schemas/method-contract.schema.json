{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/method-contract.schema.json",
  "title": "Overkill Factory Method Contract",
  "type": "object",
  "required": [
    "selected_method",
    "why_this_method",
    "risk_tier",
    "required_plans",
    "required_gates",
    "waivers",
    "canonical_scope_source",
    "scope_intent",
    "factory_route",
    "required_factory_artifacts",
    "engineering_method_matrix",
    "slice_execution_policy",
    "production_route_decision",
    "work_type",
    "selected_methods",
    "skipped_methods",
    "required_artifacts",
    "required_workers",
    "reviewers",
    "evidence_requirements",
    "authority_limit",
    "done_criteria"
  ],
  "properties": {
    "selected_method": {
      "type": "string",
      "minLength": 3
    },
    "why_this_method": {
      "type": "string",
      "minLength": 3
    },
    "risk_tier": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "required_plans": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "canonical_scope_source": {
      "type": "string",
      "minLength": 3
    },
    "scope_intent": {
      "enum": [
        "full_product",
        "child_slice",
        "bug",
        "release",
        "incident",
        "doc",
        "migration",
        "integration"
      ]
    },
    "factory_route": {
      "type": "string",
      "minLength": 3
    },
    "required_factory_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "engineering_method_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "surface_or_component",
          "methods",
          "reason",
          "required_artifacts",
          "evidence_required"
        ],
        "properties": {
          "surface_or_component": { "type": "string", "minLength": 3 },
          "methods": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
          "reason": { "type": "string", "minLength": 3 },
          "required_artifacts": { "type": "array", "items": { "type": "string" } },
          "evidence_required": { "type": "array", "items": { "type": "string" } },
          "skipped_methods": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": true
      }
    },
    "slice_execution_policy": {
      "type": "object",
      "required": [
        "slices_are_execution_units_only",
        "canonical_scope_must_not_shrink"
      ],
      "properties": {
        "slices_are_execution_units_only": { "const": true },
        "canonical_scope_must_not_shrink": { "const": true },
        "first_slice_completion_is_not_product_completion": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "production_route_decision": {
      "type": "string",
      "minLength": 3
    },
    "research_decision_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "research_route_impacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "work_type": {
      "type": "string",
      "minLength": 3
    },
    "selected_methods": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "skipped_methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "reason"
        ],
        "properties": {
          "method": {
            "type": "string",
            "minLength": 2
          },
          "reason": {
            "type": "string",
            "minLength": 3
          }
        },
        "additionalProperties": true
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "required_workers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "authority_limit": {
      "type": "string",
      "minLength": 3
    },
    "done_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  },
  "additionalProperties": true
}
