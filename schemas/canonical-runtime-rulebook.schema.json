{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/canonical-runtime-rulebook.schema.json",
  "title": "Overkill Factory Canonical Runtime Rulebook",
  "type": "object",
  "required": ["$schema", "record_type"],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/canonical-runtime-rulebook.schema.json"
    },
    "record_type": {
      "enum": ["canonical_runtime_rulebook", "canonical_runtime_gate_report"]
    },
    "source_trace_ref": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "rulebook_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "result": {
      "enum": ["PASS", "FAIL"]
    },
    "blockers": {
      "type": "array"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_id",
          "checkpoint_id",
          "sequence",
          "canonical_line",
          "canonical_heading",
          "linear_status",
          "enforcement_points",
          "required_fields",
          "block_policy"
        ],
        "properties": {
          "rule_id": {"type": "string"},
          "checkpoint_id": {"type": "string"},
          "sequence": {"type": "integer"},
          "canonical_line": {"type": "integer"},
          "canonical_heading": {"type": "string"},
          "linear_status": {"type": "string"},
          "enforcement_points": {
            "type": "array",
            "items": {"type": "string"}
          },
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "block_policy": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "non_runtime_processes": {
      "type": "array"
    },
    "unmapped_actionable_checkpoints": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
