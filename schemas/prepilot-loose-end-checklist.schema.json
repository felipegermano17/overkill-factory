{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/prepilot-loose-end-checklist.schema.json",
  "title": "Overkill Factory Prepilot Loose-End Checklist",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "items",
    "blocking_items",
    "pilot_completion_claim_allowed",
    "public_private_boundary"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/prepilot-loose-end-checklist.schema.json" },
    "record_type": { "const": "prepilot_loose_end_checklist" },
    "created_at": { "type": "string", "minLength": 10 },
    "result": { "enum": ["BLOCKED", "PASS_WITH_DEFERRED_ITEMS"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "evidence_ref", "next_action"],
        "properties": {
          "id": { "type": "string", "minLength": 3 },
          "status": { "enum": ["closed", "deferred", "blocking"] },
          "evidence_ref": { "type": "string", "minLength": 3 },
          "next_action": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": true
      }
    },
    "blocking_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 3 }
    },
    "pilot_completion_claim_allowed": { "type": "boolean" },
    "public_private_boundary": {
      "type": "object",
      "required": ["no_private_product_evidence", "no_raw_logs", "no_private_paths"],
      "properties": {
        "no_private_product_evidence": { "const": true },
        "no_raw_logs": { "const": true },
        "no_private_paths": { "const": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
