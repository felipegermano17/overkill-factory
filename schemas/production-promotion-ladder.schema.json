{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/production-promotion-ladder.schema.json",
  "title": "Overkill Factory Production Promotion Ladder",
  "type": "object",
  "required": [
    "record_type",
    "product_sot_ref",
    "target_environment",
    "environments",
    "promotion_policy",
    "owner_by_boundary",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/production-promotion-ladder.schema.json" },
    "record_type": { "const": "production_promotion_ladder" },
    "product_sot_ref": { "type": "string", "minLength": 3 },
    "target_environment": { "type": "string", "minLength": 3 },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["environment", "entry_criteria", "proof_required", "gates", "rollback_or_mitigation", "owner", "status"],
        "properties": {
          "environment": { "type": "string", "minLength": 3 },
          "entry_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "proof_required": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "gates": { "type": "array", "items": { "type": "string" } },
          "rollback_or_mitigation": { "type": "string", "minLength": 3 },
          "owner": { "type": "string", "minLength": 3 },
          "status": { "enum": ["planned", "blocked", "proven", "promoted", "verified"] },
          "post_promotion_checks": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "promotion_policy": {
      "type": "object",
      "required": [
        "preproduction_proof_cannot_claim_production",
        "human_authority_required_for_irreversible_release",
        "retest_after_promotion"
      ],
      "properties": {
        "preproduction_proof_cannot_claim_production": { "const": true },
        "human_authority_required_for_irreversible_release": { "type": "boolean" },
        "retest_after_promotion": { "const": true }
      },
      "additionalProperties": true
    },
    "onchain_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "owner_by_boundary": { "type": "object", "minProperties": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": true
}
