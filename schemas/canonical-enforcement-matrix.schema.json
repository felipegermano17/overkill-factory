{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/canonical-enforcement-matrix.schema.json",
  "title": "Overkill Factory Canonical Enforcement Matrix",
  "type": "object",
  "required": ["record_type", "scope", "canonical_doc_refs", "requirements"],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/canonical-enforcement-matrix.schema.json"
    },
    "record_type": {
      "const": "canonical_enforcement_matrix"
    },
    "scope": {
      "type": "string",
      "minLength": 10
    },
    "canonical_doc_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "claim", "source_doc_refs", "required_layers", "enforcement_refs", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]+$" },
          "claim": { "type": "string", "minLength": 10 },
          "source_doc_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          },
          "required_layers": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["contract", "runtime", "test", "evidence"] }
          },
          "enforcement_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["layer", "kind", "path", "covers"],
              "properties": {
                "layer": { "enum": ["contract", "runtime", "test", "evidence"] },
                "kind": {
                  "enum": [
                    "schema",
                    "template",
                    "script",
                    "test",
                    "worker_registry",
                    "worker_profile",
                    "profile_binding",
                    "runtime_adapter",
                    "validation_artifact"
                  ]
                },
                "path": { "type": "string", "minLength": 3 },
                "covers": { "type": "string", "minLength": 3 },
                "must_contain": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          },
          "status": { "enum": ["enforced", "bounded_public_proof"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
