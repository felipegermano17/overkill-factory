{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/factory-completion-audit.schema.json",
  "title": "Overkill Factory Practical Completion Audit",
  "type": "object",
  "required": [
    "audit_kind",
    "created_at",
    "status",
    "completion_claim_allowed",
    "score_estimate",
    "requirements_total",
    "requirements_achieved",
    "requirements_bounded",
    "requirements_blocking",
    "requirements",
    "blocking_summary",
    "blocker_economics",
    "policy_decision"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 10
    },
    "audit_kind": {
      "const": "factory_10_practical_completion"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "status": {
      "enum": ["COMPLETE", "NOT_COMPLETE"]
    },
    "completion_claim_allowed": {
      "type": "boolean"
    },
    "score_estimate": {
      "type": "string",
      "minLength": 3
    },
    "requirements_total": {
      "type": "integer"
    },
    "requirements_achieved": {
      "type": "integer"
    },
    "requirements_bounded": {
      "type": "integer"
    },
    "requirements_blocking": {
      "type": "integer"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "blocking",
          "evidence_refs",
          "why_it_matters",
          "next_action"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "status": {
            "enum": ["ACHIEVED", "BOUNDED_PUBLIC_PROOF", "BLOCKED_MISSING_EVIDENCE"]
          },
          "blocking": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 3
          },
          "boundary": {
            "type": "string"
          },
          "next_action": {
            "type": "string",
            "minLength": 3
          }
        },
        "additionalProperties": true
      }
    },
    "blocking_summary": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocker_economics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "blocker_id",
          "owner",
          "risk_controlled",
          "cost_time_class",
          "dependency",
          "smallest_safe_next_action",
          "mutation_risk",
          "route",
          "expiry",
          "status"
        ],
        "additionalProperties": true
      }
    },
    "policy_decision": {
      "type": "string",
      "minLength": 3
    }
  },
  "additionalProperties": false
}
