{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/factory-card.schema.json",
  "title": "Overkill Factory Card",
  "type": "object",
  "required": [
    "card_id",
    "slice_id",
    "owner_profile",
    "source_refs",
    "source_state",
    "outcome",
    "acceptance_criteria",
    "scope_in",
    "scope_out",
    "risk_class",
    "codex_mode",
    "review",
    "factory_method_version",
    "phase",
    "surfaces",
    "risk_initial",
    "risk_effective",
    "authority_max",
    "owner_worker",
    "executor_identity",
    "reviewer_identity",
    "runtime_decision",
    "runtime_contract",
    "security_contract",
    "forbidden_actions",
    "done_definition",
    "transition_event_required",
    "kanban_transition_event_ref"
  ],
  "properties": {
    "factory_method_version": {
      "enum": ["OVERKILL_V3_5_AGENT_WORKFORCE", "OVERKILL_V3_5_FACTORY_10", "OVERKILL_VFINAL"]
    },
    "request_type": {
      "enum": [
        "product_new",
        "slice",
        "feature",
        "bug",
        "incident",
        "release",
        "migration",
        "integration",
        "doc",
        "security",
        "ux_ui",
        "data_analytics",
        "agent_skill"
      ]
    },
    "source_state": {
      "enum": ["backlog", "compiled", "inference", "promoted", "raw", "rejected"]
    },
    "risk_initial": {
      "enum": ["R0", "R1", "R2", "R3", "R4"]
    },
    "risk_effective": {
      "enum": ["R0", "R1", "R2", "R3", "R4"]
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "executor_identity": { "type": "string", "minLength": 3 },
    "reviewer_identity": { "type": "string", "minLength": 3 },
    "runtime_contract": { "type": "object" },
    "security_contract": { "type": "object" },
    "security_role_separation": { "type": "boolean" },
    "security_role_separation_exception": { "type": "string" },
    "product_face_packet": { "$ref": "product-face-packet.schema.json" },
    "onchain_work_package": { "type": "object" },
    "security_scan_packet": { "type": "object" },
    "human_gate_packet": { "type": "object" },
    "reasoning_policy": { "$ref": "reasoning-policy.schema.json" },
    "reference_quality_packet": { "$ref": "reference-quality-packet.schema.json" },
    "r4_gate": { "type": "object" },
    "outcome_contract": { "type": "object" },
    "discovery_brief": { "type": "object" },
    "product_sot": { "type": "object" },
    "canonical_product_sot_ref": { "type": "string" },
    "scope_intent": {
      "enum": ["full_product", "child_slice", "bug", "release", "incident", "doc", "migration", "integration"]
    },
    "complete_product_required": { "type": "boolean" },
    "current_execution_slice": { "type": "string" },
    "full_product_sot_scope_coverage": { "type": "object" },
    "full_product_sot_scope_coverage_ref": { "type": "string" },
    "method_contract": { "type": "object" },
    "specialist_research_plan": { "type": "object" },
    "specialist_research_plan_ref": { "type": "string" },
    "specialist_decision_packet": { "type": "object" },
    "specialist_decision_packet_ref": { "type": "string" },
    "capability_pack_contract": { "type": "object" },
    "software_development_plan": { "type": "object" },
    "product_creation_plan": { "type": "object" },
    "product_creation_plan_ref": { "type": "string" },
    "product_context_packet": { "type": "object" },
    "product_context_packet_ref": { "type": "string" },
    "product_implementation_readiness": { "type": "object" },
    "product_implementation_readiness_ref": { "type": "string" },
    "user_facing_autonomy_contract": { "type": "object" },
    "user_facing_autonomy_contract_ref": { "type": "string" },
    "product_experience_plan": { "type": "object" },
    "data_metrics_plan": { "type": "object" },
    "agent_eval_plan": { "type": "object" },
    "spec_graph": { "type": "object" },
    "dependency_map": { "type": "object" },
    "access_capability": { "type": "object" },
    "autonomy_readiness_packet": { "type": "object" },
    "security_architecture_plan": { "type": "object" },
    "privacy_compliance_plan": { "type": "object" },
    "budget_contract": { "type": "object" },
    "production_readiness_plan": { "type": "object" },
    "production_promotion_ladder": { "type": "object" },
    "production_promotion_ladder_ref": { "type": "string" },
    "incident_support_plan": { "type": "object" },
    "legacy_migration_plan": { "type": "object" },
    "platform_devex_plan": { "type": "object" },
    "user_docs_onboarding_plan": { "type": "object" },
    "factory_maturity_scorecard": { "type": "object" },
    "loop_plan": { "type": "object" },
    "material_execution": { "type": "boolean" },
    "requires_access": { "type": "boolean" }
  },
  "additionalProperties": true
}
