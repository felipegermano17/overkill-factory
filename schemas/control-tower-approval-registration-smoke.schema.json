{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/control-tower-approval-registration-smoke.schema.json",
  "title": "Overkill Factory Control Tower Approval Registration Smoke",
  "type": "object",
  "required": [
    "$schema",
    "smoke_id",
    "result",
    "pending_approval",
    "registered_approval",
    "approval_event",
    "negative_cases",
    "registration_checks"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/control-tower-approval-registration-smoke.schema.json"
    },
    "smoke_id": { "type": "string", "minLength": 3 },
    "result": { "type": "string", "enum": ["PASS", "FAIL"] },
    "pending_approval": { "type": "object" },
    "registered_approval": { "type": "object" },
    "approval_event": { "type": "object" },
    "negative_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "registration_checks": {
      "type": "object",
      "required": [
        "valid_decision_records_event",
        "wrong_role_rejected",
        "expired_decision_rejected",
        "scope_expansion_rejected",
        "unknown_approval_rejected",
        "ambiguous_decision_rejected",
        "runtime_mutation_not_claimed"
      ],
      "properties": {
        "valid_decision_records_event": { "type": "boolean" },
        "wrong_role_rejected": { "type": "boolean" },
        "expired_decision_rejected": { "type": "boolean" },
        "scope_expansion_rejected": { "type": "boolean" },
        "unknown_approval_rejected": { "type": "boolean" },
        "ambiguous_decision_rejected": { "type": "boolean" },
        "runtime_mutation_not_claimed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
