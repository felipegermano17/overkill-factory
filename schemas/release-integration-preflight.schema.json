{
  "$id": "https://overkill-factory.dev/schemas/release-integration-preflight.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "branch",
    "counts",
    "checks",
    "release_candidate_plan",
    "blocking_items",
    "attention_items",
    "evidence_refs",
    "next_required_actions",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/release-integration-preflight.schema.json"
    },
    "record_type": {
      "const": "release_integration_preflight"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "ATTENTION", "BLOCKED"]
    },
    "branch": {
      "type": "object",
      "required": ["current", "is_main"],
      "properties": {
        "current": { "type": "string" },
        "is_main": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "counts": {
      "type": "object",
      "required": ["status_entries", "release_candidate_entries", "needs_human_review_entries"],
      "properties": {
        "status_entries": { "type": "integer", "minimum": 0 },
        "release_candidate_entries": { "type": "integer", "minimum": 0 },
        "needs_human_review_entries": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": { "type": "integer" }
    },
    "checks": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "release_candidate_plan": {
      "type": "object",
      "required": ["safe_to_prepare_candidate_branch", "recommended_branch", "why", "steps", "must_not_do"],
      "properties": {
        "safe_to_prepare_candidate_branch": { "type": "boolean" },
        "recommended_branch": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "must_not_do": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "blocking_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "attention_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_required_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
