{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-face-packet.schema.json",
  "title": "Overkill Factory Product Face Packet",
  "type": "object",
  "required": [
    "surface",
    "mode",
    "user",
    "job_to_be_done",
    "main_flows",
    "required_states",
    "design_direction",
    "visual_quality_bar",
    "proof_required",
    "reviewers_required",
    "done_definition",
    "human_gate"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/product-face-packet.schema.json"
    },
    "surface": {
      "enum": ["web_app", "website", "mobile", "desktop", "cli", "extension", "ai_interface", "design_system", "docs", "agentic_interface"]
    },
    "mode": {
      "enum": ["greenfield", "brownfield", "redesign", "qa_only", "prototype", "migration"]
    },
    "user": {
      "type": "string",
      "minLength": 3
    },
    "job_to_be_done": {
      "type": "string",
      "minLength": 3
    },
    "main_flows": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_states": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "design_direction": {
      "type": "object",
      "required": ["visual_tone", "product_fit", "density", "interaction_style"],
      "properties": {
        "visual_tone": { "type": "string", "minLength": 3 },
        "product_fit": { "type": "string", "minLength": 3 },
        "density": { "type": "string", "minLength": 3 },
        "interaction_style": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "visual_quality_bar": {
      "type": "object",
      "required": ["reference_quality_bar", "anti_generic_criteria", "professional_review_required", "block_when"],
      "properties": {
        "reference_quality_bar": { "type": "string", "minLength": 3 },
        "anti_generic_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "professional_review_required": { "type": "boolean" },
        "block_when": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "data_context": {
      "type": "string"
    },
    "accessibility_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "performance_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "device_or_viewport_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prototype_needed": {
      "enum": ["yes", "no"]
    },
    "proof_required": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "reviewers_required": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "done_definition": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "human_gate": {
      "type": "object",
      "required": ["required", "reason"],
      "properties": {
        "required": { "type": "boolean" },
        "approver": { "type": "string" },
        "reason": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
