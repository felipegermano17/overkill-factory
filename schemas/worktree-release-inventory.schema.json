{
  "$id": "https://overkill-factory.dev/schemas/worktree-release-inventory.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "result",
    "scope",
    "counts",
    "status_counts",
    "top_level_counts",
    "classification_counts",
    "cleanup_policy",
    "blocking_items",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/worktree-release-inventory.schema.json"
    },
    "record_type": {
      "const": "worktree_release_inventory"
    },
    "created_at": {
      "type": "string",
      "minLength": 10
    },
    "result": {
      "enum": ["PASS", "ATTENTION", "BLOCKED"]
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "counts": {
      "type": "object",
      "required": ["entries", "modified", "added", "deleted", "renamed", "untracked"],
      "properties": {
        "entries": { "type": "integer", "minimum": 0 },
        "modified": { "type": "integer", "minimum": 0 },
        "added": { "type": "integer", "minimum": 0 },
        "deleted": { "type": "integer", "minimum": 0 },
        "renamed": { "type": "integer", "minimum": 0 },
        "untracked": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": { "type": "integer" }
    },
    "status_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "top_level_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "classification_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "cleanup_policy": {
      "type": "object",
      "required": [
        "broad_cleanup_allowed",
        "safe_cleanup_candidates",
        "release_candidate_entries",
        "needs_human_review_entries"
      ],
      "properties": {
        "broad_cleanup_allowed": { "type": "boolean" },
        "safe_cleanup_candidates": { "type": "integer", "minimum": 0 },
        "release_candidate_entries": { "type": "integer", "minimum": 0 },
        "needs_human_review_entries": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "blocking_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
