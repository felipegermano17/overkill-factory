{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-context-packet.schema.json",
  "title": "Overkill Factory Product Context Packet",
  "type": "object",
  "required": [
    "record_type",
    "context_id",
    "product_sot_ref",
    "method_contract_ref",
    "product_creation_plan_ref",
    "technology_stack",
    "critical_implementation_rules",
    "security_and_privacy_rules",
    "testing_and_verification_rules",
    "generic_patterns_to_avoid",
    "stop_conditions",
    "refresh_policy",
    "public_safety_policy",
    "evidence_refs"
  ],
  "properties": {
    "$schema": { "const": "https://overkill-factory.dev/schemas/product-context-packet.schema.json" },
    "record_type": { "const": "product_context_packet" },
    "context_id": { "type": "string", "minLength": 3 },
    "product_sot_ref": { "type": "string", "minLength": 3 },
    "method_contract_ref": { "type": "string", "minLength": 3 },
    "architecture_decision_refs": { "type": "array", "items": { "type": "string" } },
    "product_creation_plan_ref": { "type": "string", "minLength": 3 },
    "product_experience_refs": { "type": "array", "items": { "type": "string" } },
    "technology_stack": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "critical_implementation_rules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "folder_and_file_conventions": { "type": "array", "items": { "type": "string" } },
    "api_and_data_contracts": { "type": "array", "items": { "type": "string" } },
    "security_and_privacy_rules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "testing_and_verification_rules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "ux_and_product_face_rules": { "type": "array", "items": { "type": "string" } },
    "release_and_operations_rules": { "type": "array", "items": { "type": "string" } },
    "generic_patterns_to_avoid": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "prior_worker_learnings": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "refresh_policy": { "type": "string", "minLength": 8 },
    "stale": { "type": "boolean" },
    "public_safety_policy": { "type": "string", "minLength": 8 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    }
  },
  "additionalProperties": true
}
