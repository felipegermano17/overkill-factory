{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/user-facing-autonomy-contract.schema.json",
  "title": "User-Facing Autonomy Contract",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "intake_source",
    "user_roles",
    "factory_owns",
    "user_must_not_do",
    "allowed_user_question_classes",
    "human_gate_triggers",
    "approval_points",
    "autonomy_level",
    "handoff_mode",
    "blocked_state_policy",
    "burden_budget",
    "surface_map"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/user-facing-autonomy-contract.schema.json"
    },
    "record_type": { "const": "user_facing_autonomy_contract" },
    "intake_source": {
      "enum": ["paper", "repo", "prompt", "docs", "issue", "incident", "research_request", "release_request", "mixed"]
    },
    "user_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["submitter", "approver", "reviewer", "risk_owner", "access_provider", "product_owner", "maintainer"]
      }
    },
    "factory_owns": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "user_must_not_do": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "allowed_user_question_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["preference", "authority_required", "access_required", "risk_acceptance", "blocked"]
      }
    },
    "user_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "class", "factory_resolution_path"],
        "properties": {
          "question": { "type": "string", "minLength": 3 },
          "class": {
            "enum": ["discoverable", "preference", "authority_required", "access_required", "risk_acceptance", "blocked"]
          },
          "factory_resolution_path": { "type": "string", "minLength": 3 }
        },
        "additionalProperties": false
      }
    },
    "human_gate_triggers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "approval_points": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3 }
    },
    "autonomy_level": {
      "enum": ["advisory", "planning_only", "supervised_execution", "gated_autonomous_execution", "production_autonomous_operation"]
    },
    "handoff_mode": { "type": "string", "minLength": 3 },
    "blocked_state_policy": { "type": "string", "minLength": 3 },
    "burden_budget": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase", "allowed_user_work", "factory_work"],
        "properties": {
          "phase": { "type": "string", "minLength": 2 },
          "allowed_user_work": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 }
          },
          "factory_work": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 }
          }
        },
        "additionalProperties": false
      }
    },
    "surface_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability", "internal", "user_facing", "maintainer_facing"],
        "properties": {
          "capability": { "type": "string", "minLength": 3 },
          "internal": { "type": "boolean" },
          "user_facing": { "type": "boolean" },
          "maintainer_facing": { "type": "boolean" },
          "normal_user_view": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
