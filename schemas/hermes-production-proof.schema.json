{
  "$id": "https://overkill-factory.dev/schemas/hermes-production-proof.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "record_type",
    "created_at",
    "proof_type",
    "result",
    "summary",
    "scope",
    "environment_ref",
    "evidence_refs",
    "limits"
  ],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/hermes-production-proof.schema.json"
    },
    "record_type": {
      "const": "hermes_production_proof"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "proof_type": {
      "enum": [
        "non_stub_worker_execution",
        "real_tool_auth",
        "specialist_output_quality",
        "real_worker_done_reconciliation",
        "production_rollback_monitoring",
        "operator_control_tower"
      ]
    },
    "result": {
      "const": "PASS"
    },
    "summary": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string",
      "minLength": 3
    },
    "environment_ref": {
      "type": "string",
      "minLength": 3
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision": {
      "type": "object",
      "properties": {
        "real_runtime_update": {
          "enum": [
            "allowed_for_explicit_operator_gate",
            "not_applicable"
          ]
        }
      }
    }
  }
}
