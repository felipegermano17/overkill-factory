{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://overkill-factory.dev/schemas/product-face-result.schema.json",
  "title": "Overkill Factory Product Face Result",
  "type": "object",
  "required": [
    "result",
    "tool_or_profile",
    "executed_by",
    "screenshots",
    "viewports",
    "checked_states",
    "user_journeys_checked",
    "a11y",
    "overlap_check",
    "performance_note",
    "packet_comparison",
    "source_promise_coverage",
    "design_fit_review",
    "visual_quality_result",
    "blocking_findings",
    "evidence_refs",
    "evidence_kind",
    "reusable_for_product",
    "next_action"
  ],
  "properties": {
    "result": {
      "enum": ["PASS", "WAIVED"]
    },
    "tool_or_profile": {
      "type": "string",
      "minLength": 3
    },
    "executed_by": {
      "type": "string",
      "minLength": 3
    },
    "screenshots": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "viewports": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "checked_states": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "user_journeys_checked": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "a11y": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail"] }
      },
      "additionalProperties": true
    },
    "overlap_check": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail"] }
      },
      "additionalProperties": true
    },
    "console": {
      "type": "object",
      "properties": {
        "status": { "enum": ["pass", "warn", "fail"] }
      },
      "additionalProperties": true
    },
    "performance_note": {
      "type": "string",
      "minLength": 3
    },
    "packet_ref": {
      "type": "string"
    },
    "packet_comparison": {
      "type": "object",
      "required": ["status", "basis"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail", "pending"] },
        "basis": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "source_promise_coverage": {
      "type": "object",
      "required": ["status", "basis"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail", "pending"] },
        "basis": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "design_fit_review": {
      "type": "object",
      "required": ["status", "basis"],
      "properties": {
        "status": { "enum": ["pass", "warn", "fail", "pending"] },
        "basis": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": true
    },
    "visual_quality_result": {
      "type": "object",
      "required": ["status", "reviewer", "basis", "reference_quality_bar_checked", "ai_generic_symptoms"],
      "properties": {
        "status": { "enum": ["PASS", "BLOCK", "PASS_WITH_RESIDUALS"] },
        "reviewer": { "type": "string", "minLength": 3 },
        "basis": { "type": "string", "minLength": 3 },
        "reference_quality_bar_checked": { "type": "boolean" },
        "ai_generic_symptoms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "residuals": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "blocking_findings": {
      "type": "boolean"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_kind": {
      "enum": ["real", "synthetic", "waiver"]
    },
    "reusable_for_product": {
      "type": "boolean"
    },
    "next_action": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
