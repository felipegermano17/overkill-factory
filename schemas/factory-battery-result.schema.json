{
  "$id": "https://overkill-factory.dev/schemas/factory-battery-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["$schema", "result_type", "scenario_count", "passed_count", "failed_count", "scenarios"],
  "properties": {
    "$schema": {
      "const": "https://overkill-factory.dev/schemas/factory-battery-result.schema.json"
    },
    "result_type": {
      "const": "factory_validation_battery"
    },
    "scenario_count": {
      "type": "integer"
    },
    "passed_count": {
      "type": "integer"
    },
    "failed_count": {
      "type": "integer"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}
