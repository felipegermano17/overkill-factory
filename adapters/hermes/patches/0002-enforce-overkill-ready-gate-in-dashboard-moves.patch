+def _last_failure_error(conn: sqlite3.Connection, task_id: str) -> Optional[str]:
+    row = conn.execute(
+        "SELECT last_failure_error FROM tasks WHERE id = ?",
+        (task_id,),
+    ).fetchone()
+    if row is None:
+        return None
+    value = row["last_failure_error"]
+    return str(value) if value else None
+
+
+def _block_ready_task_on_overkill_gate_error(
+    conn: sqlite3.Connection,
+    task_id: str,
+) -> Optional[str]:
+    """Re-run the kernel ready gate after dashboard edits/reassignments.
+
+    ``create_task``, ``promote_task``, ``unblock_task``, ``recompute_ready``
+    and ``claim_task`` already enforce the Overkill ready contract. Dashboard
+    PATCH can still mutate a card that is already ``ready``; this guard keeps
+    those post-gate mutations from leaving invalid work dispatchable.
+    """
+    with kanban_db.write_txn(conn):
+        row = conn.execute(
+            "SELECT status, title, body, assignee FROM tasks WHERE id = ?",
+            (task_id,),
+        ).fetchone()
+        if row is None or row["status"] != "ready":
+            return None
+        gate_error = kanban_db._overkill_ready_gate_error(
+            row["title"], row["body"], row["assignee"]
+        )
+        if not gate_error:
+            return None
+        conn.execute(
+            "UPDATE tasks SET status = 'blocked', consecutive_failures = 0, last_failure_error = ? "
+            "WHERE id = ? AND status = 'ready'",
+            (gate_error, task_id),
+        )
+        kanban_db._append_event(conn, task_id, "blocked", {"reason": gate_error})
+        return gate_error
+
+
