+def test_patch_ready_uses_overkill_gate_for_direct_dashboard_move(client):
+    """Dashboard drag-drop must not bypass the Factory ready gate."""
+    card = _base_card(owner="frontend-worker", surfaces=["ux", "frontend"])
+    card.pop("product_face_packet")
+
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="invalid factory card",
+            body=_body(card),
+            assignee="frontend-worker",
+            initial_status="blocked",
+        )
+        with kb.write_txn(conn):
+            conn.execute("UPDATE tasks SET status = 'todo' WHERE id = ?", (tid,))
+
+    r = client.patch(
+        f"/api/plugins/kanban/tasks/{tid}",
+        json={"status": "ready"},
+    )
+
+    assert r.status_code == 409
+    assert "product_face_packet" in r.json()["detail"]
+    detail = client.get(f"/api/plugins/kanban/tasks/{tid}").json()["task"]
+    assert detail["status"] == "blocked"
+    assert "product_face_packet" in detail["last_failure_error"]
+
+
+def test_patch_body_edit_rechecks_ready_overkill_card(client):
+    """Editing a ready Factory card cannot leave invalid work dispatchable."""
+    valid_card = _base_card(owner="frontend-worker", surfaces=["ux", "frontend"])
+    invalid_card = dict(valid_card)
+    invalid_card.pop("product_face_packet")
+
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="valid factory card",
+            body=_body(valid_card),
+            assignee="frontend-worker",
+        )
+        assert kb.get_task(conn, tid).status == "ready"
+
+    r = client.patch(
+        f"/api/plugins/kanban/tasks/{tid}",
+        json={"body": _body(invalid_card)},
+    )
+
+    assert r.status_code == 409
+    assert "product_face_packet" in r.json()["detail"]
+    detail = client.get(f"/api/plugins/kanban/tasks/{tid}").json()["task"]
+    assert detail["status"] == "blocked"
+    assert "product_face_packet" in detail["last_failure_error"]
+
+
