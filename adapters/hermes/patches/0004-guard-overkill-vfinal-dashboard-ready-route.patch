+def _is_overkill_factory_card(task: kanban_db.Task) -> bool:
+    """Return True when the task body is an Overkill Factory card."""
+    parser = getattr(kanban_db, "_overkill_parse_factory_card_body", None)
+    if not callable(parser):
+        return False
+    try:
+        return parser(task.body or "") is not None
+    except Exception:
+        return False
+
+
+def _set_ready_status(
+    conn: sqlite3.Connection,
+    task_id: str,
+    *,
+    actor: str,
+    reason: str,
+) -> tuple[bool, Optional[str]]:
+    """Move a task to ready through the safest route for its contract."""
+    current = kanban_db.get_task(conn, task_id)
+    if current is None:
+        return False, "task not found"
+
+    if _is_overkill_factory_card(current):
+        if current.status == "scheduled":
+            ok = kanban_db.unblock_task(conn, task_id)
+            if ok:
+                return True, None
+            return False, "Overkill Factory gate refused scheduled -> ready"
+        if current.status in ("todo", "blocked"):
+            return kanban_db.promote_task(
+                conn,
+                task_id,
+                actor=actor,
+                reason=reason,
+            )
+        return False, (
+            "Overkill Factory cards cannot move directly to 'ready' "
+            f"from {current.status!r}; use a gated promote/unblock path"
+        )
+
+    # Re-open a blocked/scheduled task, or just an explicit status set.
+    if current.status in ("blocked", "scheduled"):
+        ok = kanban_db.unblock_task(conn, task_id)
+    else:
+        ok = _set_status_direct(conn, task_id, "ready")
+    return ok, None


