+def test_v35_worker_cli_completion_keeps_running_until_product_face_result(
+    kanban_home: Path,
+    monkeypatch: pytest.MonkeyPatch,
+    capsys: pytest.CaptureFixture[str],
+) -> None:
+    card = _base_card(owner="overkill-frontend", surfaces=["ux", "frontend"], phase="F13")
+
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="worker product face completion fixture",
+            body=_body(card),
+            assignee="overkill-frontend",
+            initial_status="blocked",
+        )
+        ok, err = kb.promote_task(conn, tid, actor="pytest")
+        assert ok is True
+        assert err is None
+        assert kb.claim_task(conn, tid) is not None
+        run_id = kb.get_task(conn, tid).current_run_id
+        assert run_id is not None
+
+    monkeypatch.setenv("HERMES_KANBAN_TASK", tid)
+    monkeypatch.setenv("HERMES_KANBAN_RUN_ID", str(run_id))
+
+    missing_meta = _receipt_metadata(include_scan=False)
+    rc = kanban_cli._cmd_complete(
+        SimpleNamespace(
+            task_ids=[tid],
+            result="missing product face proof",
+            summary="Receipt Five exists but browser/product evidence is missing",
+            metadata=json.dumps(missing_meta),
+        )
+    )
+
+    captured = capsys.readouterr()
+    assert rc == 1
+    assert "cannot complete" in captured.err
+    assert "product_face_result metadata is required" in captured.err
+    with kb.connect() as conn:
+        task = kb.get_task(conn, tid)
+        events = kb.list_events(conn, tid)
+        assert task.status == "running"
+        assert task.current_run_id == run_id
+        assert events[-1].kind == "completion_blocked_overkill_gate"
+
+    complete_meta = _receipt_metadata(include_scan=False)
+    complete_meta["product_face_result"] = _product_face_result()
+    rc = kanban_cli._cmd_complete(
+        SimpleNamespace(
+            task_ids=[tid],
+            result="product face proof passed",
+            summary="Receipt Five and Product Face result accepted",
+            metadata=json.dumps(complete_meta),
+        )
+    )
+
+    captured = capsys.readouterr()
+    assert rc == 0
+    assert f"Completed {tid}" in captured.out
+    with kb.connect() as conn:
+        task = kb.get_task(conn, tid)
+        run = kb.latest_run(conn, tid)
+        assert task.status == "done"
+        assert task.current_run_id is None
+        assert run.metadata["product_face_result"]["record_type"] == "product_face_result"
+
+
