+            initial_status="blocked",
+        )
+        ok, err = kb.promote_task(conn, tid, actor="pytest")
+        assert ok is True
+        assert err is None
+
+        with pytest.raises(ValueError, match="security_scan_result metadata is required"):
+            kb.complete_task(
+                conn,
+                tid,
+                result="missing scan",
+                summary="Receipt Five exists but scan result is missing",
+                metadata=_receipt_metadata(include_scan=False),
+            )
+        assert kb.get_task(conn, tid).status == "ready"
+
+        assert kb.complete_task(
+            conn,
+            tid,
+            result="scan passed",
+            summary="Receipt Five and security scan result accepted",
+            metadata=_receipt_metadata(include_scan=True),
+        )
+        assert kb.get_task(conn, tid).status == "done"
