 if __name__ == "__main__":
diff --git a/tests/hermes_cli/test_kaxis_factory_v35_gate.py b/tests/hermes_cli/test_kaxis_factory_v35_gate.py
new file mode 100644
index 000000000..e71b1de0a
--- /dev/null
+++ b/tests/hermes_cli/test_kaxis_factory_v35_gate.py
@@ -0,0 +1,382 @@
+"""Regression tests for the opt-in KAXIS Factory v3.5 Kanban gate.
+
+The gate is intentionally machine-checkable: KAXIS factory cards must not
+advance because an agent writes convincing prose. They must carry enough
+structured context for autonomous workers, reviewers, security scanners, and
+human gates to make the next transition safely.
+"""
+
+from __future__ import annotations
+
+import json
+import sys
+from pathlib import Path
+
+import pytest
+
+from hermes_cli import kanban_db as kb
+
+
+@pytest.fixture
+def kanban_home(tmp_path: Path, monkeypatch: pytest.MonkeyPatch) -> Path:
+    home = tmp_path / ".hermes"
+    home.mkdir()
+    monkeypatch.setenv("HERMES_HOME", str(home))
+    monkeypatch.delenv("HERMES_KANBAN_DB", raising=False)
+    monkeypatch.delenv("HERMES_KANBAN_HOME", raising=False)
+    monkeypatch.setattr(Path, "home", lambda: tmp_path)
+    db_path = kb.kanban_db_path(board="default")
+    kb._INITIALIZED_PATHS.discard(str(db_path.resolve()))
+    kb.init_db(board="default")
+    return home
+
+
+def _body(card: dict) -> str:
+    return "```json\n" + json.dumps(card, ensure_ascii=False) + "\n```"
+
+
+def _review(*, risk: str) -> dict[str, bool]:
+    required = risk in {
+        "R2-product-sensitive",
+        "R3-financial-critical",
+        "R4-production-critical",
+    }
+    high = risk in {"R3-financial-critical", "R4-production-critical"}
+    return {
+        "QA_required": required,
+        "independent_review_required": required,
+        "security_review_required": required,
+        "cybersecurity_review_required": high,
+        "CTO_gate_required": high,
+        "Felipe_gate_required": high,
+    }
+
+
+def _product_face_packet() -> dict:
+    return {
+        "screen_inventory": ["factory status", "evidence detail"],
+        "state_matrix": {
+            "loading": "shown",
+            "error": "shown",
+            "success": "shown",
+        },
+        "design_contract_ref": "design-contract-test",
+        "mobile_breakpoints": ["375", "768", "1440"],
+        "wallet_flow_matrix": {
+            "sign": "not_applicable_test",
+            "reject": "not_applicable_test",
+        },
+        "a11y_acceptance": ["keyboard", "focus", "contrast"],
+        "performance_budget": {"render": "not_applicable_test"},
+        "visual_evidence_plan": ["desktop screenshot", "mobile screenshot"],
+    }
+
+
+def _security_scan_packet() -> dict:
+    return {
+        "security_owner": "kaxis-security",
+        "scanner_agent": "kaxis-cybersecurity",
+        "scan_timing": "before_done",
+        "scan_scope": ["card contract", "agent handoff", "runtime boundary"],
+        "required_tools": ["codex-security:security-scan", "cybersecurity-review"],
+        "acceptance_policy": {
+            "blocking_findings_allowed": False,
+            "waiver_requires_human": True,
+            "evidence_required": True,
+        },
+    }
+
+
+def _onchain_package(*, auditor_required: bool = True) -> dict:
+    return {
+        "quasar_source_ref": "quasar-docs",
+        "framework_default": "quasar_non_anchor",
+        "account_map": ["test_account"],
+        "instruction_abi": ["test_instruction"],
+        "pda_derivation": ["seed:test"],
+        "cpi_allowlist": ["none"],
+        "compute_unit_budget": "test_only",
+        "auditor_required": auditor_required,
+    }
+
+
+def _r4_gate() -> dict:
+    return {
+        "human_approval_ref": "felipe-approval-test",
+        "rollback_plan": "restore previous release and block dispatcher",
+        "risk_owner": "kaxis-cto",
+        "security_owner": "kaxis-security",
+    }
+
+
+def _base_card(
+    *,
+    owner: str = "kaxis-frontend",
+    surfaces: list[str] | None = None,
+    risk: str = "R1-dev-safe",
+    risk_effective: str | None = None,
+    codex_mode: str | None = None,
+    phase: str = "F5",
+) -> dict:
+    effective = risk_effective or {
+        "R0-docs-only": "R0",
+        "R1-dev-safe": "R1",
+        "R2-product-sensitive": "R2",
+        "R3-financial-critical": "R3",
+        "R4-production-critical": "R4",
+    }[risk]
+    card = {
+        "card_id": "KFP-V35-TEST",
+        "slice_id": "KAXIS_FACTORY_V35_TEST",
+        "owner_profile": owner,
+        "source_refs": ["KAXIS Factory v3.5 regression test"],
+        "source_state": "compiled",
+        "outcome": "Validate KAXIS Factory 10 Kanban gate behavior in a deterministic test.",
+        "acceptance_criteria": ["gate returns the expected transition decision"],
+        "scope_in": ["unit test only"],
+        "scope_out": ["deploy", "secret access", "funds", "mainnet"],
+        "target_repo_paths": ["tests/hermes_cli"],
+        "conflict_set": ["agent prose is not transition evidence"],
+        "risk_class": risk,
+        "why_this_class": "The test exercises the local Kanban gate without sensitive runtime action.",
+        "codex_mode": codex_mode or ("required" if risk == "R4-production-critical" else "advisory"),
+        "why_codex_mode": "Codex is only validating the local Kanban transition contract.",
+        "product_security_checks": ["no product approval"],
+        "code_security_checks": ["no code execution outside the test"],
+        "system_security_checks": ["no infrastructure mutation"],
+        "process_security_checks": ["structured transition evidence required"],
+        "verify_commands": ["pytest tests/hermes_cli/test_kaxis_factory_v35_gate.py"],
+        "evidence_expected": ["expected gate decision is observed"],
+        "review": _review(risk=risk),
+        "factory_method_version": "KAXIS_V3_5_FACTORY_10",
+        "phase": phase,
+        "surfaces": surfaces or ["ux", "frontend"],
+        "risk_initial": effective,
+        "risk_effective": effective,
+        "authority_max": "validate_gate_only",
+        "owner_worker": "KAXIS Test Worker",
+        "executor_identity": owner,
+        "reviewer_identity": "kaxis-reviewer",
+        "runtime_decision": "hermes_test_runtime",
+        "runtime_contract": {"mode": "unit_test"},
+        "security_contract": {"security_boundary": "no_sensitive_action"},
+        "forbidden_actions": ["deploy", "secret_access", "funds", "mainnet"],
+        "done_definition": "The gate returns the expected transition decision.",
+        "transition_event_required": True,
+        "kanban_transition_event_ref": "unit-test-transition",
+    }
+    if set(card["surfaces"]) & {"ux", "frontend", "mobile", "wallet-ui"}:
+        card["product_face_packet"] = _product_face_packet()
+    if risk in {"R3-financial-critical", "R4-production-critical"}:
+        card["rollback_or_recovery"] = "Keep the task blocked until a human approves the gate."
+        card["protected_assets"] = ["KAXIS runtime", "KAXIS authority boundary"]
+    return card
+
+
