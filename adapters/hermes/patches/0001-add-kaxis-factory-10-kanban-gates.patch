diff --git a/hermes_cli/kanban_db.py b/hermes_cli/kanban_db.py
index b2e03151b..e4e19ec59 100644
--- a/hermes_cli/kanban_db.py
+++ b/hermes_cli/kanban_db.py
@@ -158,6 +158,344 @@ _KAXIS_REVIEW_REQUIRED = [
     "Felipe_gate_required",
 ]
 
+# KAXIS v3.5 factory gate is opt-in. Existing v2 cards keep the historical
+# contract, while new factory cards can ask Hermes to enforce the stronger
+# Agent Workforce rules before ready/done.
+_KAXIS_V35_METHOD_VERSIONS = {
+    "KAXIS_V3_5_AGENT_WORKFORCE",
+    "KAXIS_V3_5_FACTORY_10",
+}
+_KAXIS_V35_REQUIRED = [
+    "factory_method_version",
+    "phase",
+    "surfaces",
+    "risk_initial",
+    "risk_effective",
+    "authority_max",
+    "owner_worker",
+    "executor_identity",
+    "reviewer_identity",
+    "runtime_decision",
+    "runtime_contract",
+    "security_contract",
+    "forbidden_actions",
+    "done_definition",
+    "transition_event_required",
+    "kanban_transition_event_ref",
+]
+_KAXIS_V35_RISKS = {"R0", "R1", "R2", "R3", "R4"}
+_KAXIS_V35_RISK_FROM_V2 = {
+    "R0-docs-only": "R0",
+    "R1-dev-safe": "R1",
+    "R2-product-sensitive": "R2",
+    "R3-financial-critical": "R3",
+    "R4-production-critical": "R4",
+}
+_KAXIS_V35_RISK_ORDER = {"R0": 0, "R1": 1, "R2": 2, "R3": 3, "R4": 4}
+_KAXIS_V35_PRODUCT_FACE_SURFACES = {"ux", "frontend", "mobile", "wallet-ui"}
+_KAXIS_V35_ONCHAIN_SURFACES = {
+    "solana-quasar",
+    "account-pda",
+    "cpi",
+    "compute-units",
+    "token-kx",
+    "custody",
+    "signer-authority",
+    "defi-oracle",
+    "funds",
+    "mainnet",
+}
+_KAXIS_V35_SECURITY_SURFACES = {
+    "security",
+    "cybersecurity",
+    "prompt-injection",
+    "agent-runtime",
+    "external-tool",
+    "supply-chain",
+    "secrets",
+    "iam",
+    "dns",
+    "kms",
+}
+_KAXIS_V35_SECURITY_TOOL_MARKERS = {
+    "codex-security",
+    "codex_security",
+    "codex security",
+    "cybersecurity",
+    "cibersecurity",
+}
+
+
+def _kaxis_is_v35_card(card: dict[str, Any]) -> bool:
+    version = str(card.get("factory_method_version") or "").strip()
+    return version in _KAXIS_V35_METHOD_VERSIONS
+
+
+def _kaxis_non_empty_dict(value: object) -> bool:
+    return isinstance(value, dict) and bool(value)
+
+
+def _kaxis_v35_surfaces(card: dict[str, Any]) -> set[str]:
+    raw = card.get("surfaces")
+    if not isinstance(raw, list):
+        return set()
+    return {str(item).strip().lower() for item in raw if str(item).strip()}
+
+
+def _kaxis_v35_has_human_waiver(value: object) -> bool:
+    if not isinstance(value, dict):
+        return False
+    owner = value.get("human_owner") or value.get("owner") or value.get("human_gate_ref")
+    reason = value.get("reason")
+    return _kaxis_non_empty_string(owner) and _kaxis_non_empty_string(reason, 10)
+
+
+def _kaxis_v35_has_security_tool(value: object) -> bool:
+    values = value if isinstance(value, list) else [value]
+    for item in values:
+        normalized = str(item or "").strip().lower()
+        if not normalized:
+            continue
+        if any(marker in normalized for marker in _KAXIS_V35_SECURITY_TOOL_MARKERS):
+            return True
+    return False
+
+
+def _kaxis_v35_requires_security_scan(
+    card: dict[str, Any],
+    surfaces: set[str],
+    risk_effective: str,
+) -> bool:
+    if card.get("security_scan_packet_required") is True:
+        return True
+    return bool(
+        risk_effective in {"R3", "R4"}
+        or surfaces & _KAXIS_V35_ONCHAIN_SURFACES
+        or surfaces & _KAXIS_V35_SECURITY_SURFACES
+    )
+
+
+def _kaxis_validate_v35_card(card: dict[str, Any], risk_class: object) -> list[str]:
+    if not _kaxis_is_v35_card(card):
+        return []
+    errors: list[str] = []
+    missing = [key for key in _KAXIS_V35_REQUIRED if key not in card]
+    if missing:
+        errors.append("v3.5 missing " + ", ".join(missing))
+
+    for key in ("phase", "risk_initial", "risk_effective"):
+        if key in card and not _kaxis_non_empty_string(card.get(key), 2):
+            errors.append(f"v3.5 {key} must be a non-empty string")
+
+    for key in (
+        "authority_max",
+        "owner_worker",
+        "executor_identity",
+        "reviewer_identity",
+        "runtime_decision",
+        "done_definition",
+        "kanban_transition_event_ref",
+    ):
+        if key in card and not _kaxis_non_empty_string(card.get(key)):
+            errors.append(f"v3.5 {key} must be a non-empty string")
+
+    surfaces = _kaxis_v35_surfaces(card)
+    if not surfaces:
+        errors.append("v3.5 surfaces must be a non-empty string array")
+
+    risk_initial = str(card.get("risk_initial") or "").strip()
+    risk_effective = str(card.get("risk_effective") or "").strip()
+    if risk_initial and risk_initial not in _KAXIS_V35_RISKS:
+        errors.append("v3.5 risk_initial must be one of R0, R1, R2, R3, R4")
+    if risk_effective and risk_effective not in _KAXIS_V35_RISKS:
+        errors.append("v3.5 risk_effective must be one of R0, R1, R2, R3, R4")
+    mapped_v2 = _KAXIS_V35_RISK_FROM_V2.get(str(risk_class or ""))
+    if mapped_v2 and risk_effective in _KAXIS_V35_RISKS:
+        if _KAXIS_V35_RISK_ORDER[risk_effective] < _KAXIS_V35_RISK_ORDER[mapped_v2]:
+            errors.append("v3.5 risk_effective cannot be lower than risk_class")
+
+    if not _kaxis_non_empty_string_list(card.get("forbidden_actions")):
+        errors.append("v3.5 forbidden_actions must be a non-empty string array")
+    if not isinstance(card.get("transition_event_required"), bool):
+        errors.append("v3.5 transition_event_required must be boolean")
+
+    executor = str(card.get("executor_identity") or "").strip().lower()
+    reviewer = str(card.get("reviewer_identity") or "").strip().lower()
+    if executor and reviewer and executor == reviewer:
+        errors.append("v3.5 executor_identity and reviewer_identity must be distinct")
+
+    if not _kaxis_non_empty_dict(card.get("runtime_contract")):
+        errors.append("v3.5 runtime_contract must be an object")
+    if not _kaxis_non_empty_dict(card.get("security_contract")):
+        errors.append("v3.5 security_contract must be an object")
+
+    if surfaces & _KAXIS_V35_PRODUCT_FACE_SURFACES:
+        packet = card.get("product_face_packet")
+        if not _kaxis_non_empty_dict(packet):
+            errors.append("v3.5 product_face_packet is required for UX/frontend/mobile/wallet surfaces")
+        else:
+            required = [
+                "screen_inventory",
+                "state_matrix",
+                "design_contract_ref",
+                "mobile_breakpoints",
+                "a11y_acceptance",
+                "performance_budget",
+                "visual_evidence_plan",
+            ]
+            if "wallet-ui" in surfaces:
+                required.append("wallet_flow_matrix")
+            missing_packet = [key for key in required if key not in packet or not packet.get(key)]
+            if missing_packet:
+                errors.append("v3.5 product_face_packet missing " + ", ".join(missing_packet))
+
+    onchain = surfaces & _KAXIS_V35_ONCHAIN_SURFACES
+    if onchain:
+        package = card.get("onchain_work_package")
+        if not _kaxis_non_empty_dict(package):
+            errors.append("v3.5 onchain_work_package is required for onchain surfaces")
+        else:
+            required = [
+                "quasar_source_ref",
+                "framework_default",
+                "account_map",
+                "instruction_abi",
+                "pda_derivation",
+                "cpi_allowlist",
+                "compute_unit_budget",
+            ]
+            missing_package = [key for key in required if key not in package or package.get(key) in (None, "", [])]
+            if missing_package:
+                errors.append("v3.5 onchain_work_package missing " + ", ".join(missing_package))
+            if risk_effective in {"R3", "R4"}:
+                waiver = package.get("auditor_waiver") or card.get("auditor_waiver")
+                if package.get("auditor_required") is not True and not _kaxis_v35_has_human_waiver(waiver):
+                    errors.append("v3.5 onchain R3/R4 requires auditor_required=true or human auditor_waiver")
+
+    if surfaces & _KAXIS_V35_SECURITY_SURFACES and risk_effective in {"R3", "R4"}:
+        separation = card.get("security_role_separation")
+        exception = card.get("security_role_separation_exception")
+        if separation is not True and not _kaxis_non_empty_dict(exception):
+            errors.append("v3.5 R3/R4 security surfaces require role separation or explicit exception")
+
+    if _kaxis_v35_requires_security_scan(card, surfaces, risk_effective):
+        packet = card.get("security_scan_packet")
+        if not _kaxis_non_empty_dict(packet):
+            errors.append("v3.5 security_scan_packet is required for R3/R4, onchain or security surfaces")
+        else:
+            required = ["security_owner", "scanner_agent", "scan_timing"]
+            missing_scan = [
+                key for key in required
+                if not _kaxis_non_empty_string(packet.get(key), 4)
+            ]
+            if missing_scan:
+                errors.append("v3.5 security_scan_packet missing " + ", ".join(missing_scan))
+            if not _kaxis_non_empty_string_list(packet.get("scan_scope")):
+                errors.append("v3.5 security_scan_packet scan_scope must be a non-empty string array")
+            if not _kaxis_non_empty_string_list(packet.get("required_tools")):
+                errors.append("v3.5 security_scan_packet required_tools must be a non-empty string array")
+            elif not _kaxis_v35_has_security_tool(packet.get("required_tools")):
+                errors.append("v3.5 security_scan_packet required_tools must include Codex Security or cybersecurity")
+            if not _kaxis_non_empty_dict(packet.get("acceptance_policy")):
+                errors.append("v3.5 security_scan_packet acceptance_policy must be an object")
+
+    if risk_effective == "R4" or risk_class == "R4-production-critical":
+        gate = card.get("r4_gate")
+        if not _kaxis_non_empty_dict(gate):
+            errors.append("v3.5 R4 requires r4_gate")
+        else:
+            required = ["human_approval_ref", "rollback_plan", "risk_owner", "security_owner"]
+            missing_gate = [key for key in required if not _kaxis_non_empty_string(gate.get(key), 4)]
+            if missing_gate:
+                errors.append("v3.5 r4_gate missing " + ", ".join(missing_gate))
+
+    return errors
+
+
+def _kaxis_validate_v35_completion(card: dict[str, Any], metadata: Optional[dict]) -> list[str]:
+    if not _kaxis_is_v35_card(card):
+        return []
+    errors: list[str] = []
+    if not isinstance(metadata, dict):
+        return ["v3.5 completion requires metadata"]
+
+    receipt = metadata.get("receipt_five")
+    if not _kaxis_non_empty_dict(receipt):
+        errors.append("v3.5 receipt_five metadata is required")
+    else:
+        required = [
+            "changed",
+            "artifact_paths",
+            "verification_commands",
+            "verification_result",
+            "reviewer_required",
+            "next_action",
+        ]
+        missing_receipt = [key for key in required if key not in receipt or receipt.get(key) in (None, "", [])]
+        if missing_receipt:
+            errors.append("v3.5 receipt_five missing " + ", ".join(missing_receipt))
+        if receipt.get("reviewer_required") is True and not receipt.get("reviewer_result"):
+            errors.append("v3.5 receipt_five reviewer_result required when reviewer_required=true")
+
+    event = metadata.get("kanban_transition_event")
+    if not _kaxis_non_empty_dict(event):
+        errors.append("v3.5 kanban_transition_event metadata is required")
+    else:
+        required = ["from_status", "to_status", "actor", "worker", "receipt_refs", "artifact_refs"]
+        missing_event = [key for key in required if key not in event or event.get(key) in (None, "", [])]
+        if missing_event:
+            errors.append("v3.5 kanban_transition_event missing " + ", ".join(missing_event))
+
+    if card.get("promotion_packet_required") is True:
+        packet = metadata.get("promotion_packet")
+        if not _kaxis_non_empty_dict(packet):
+            errors.append("v3.5 promotion_packet metadata is required")
+        else:
+            required = [
+                "promotion_packet_id",
+                "slice_id",
+                "included_work_packages",
+                "evidence_refs",
+                "residual_risk",
+                "rollback",
+                "monitoring",
+                "decision_requested",
+            ]
+            missing_packet = [key for key in required if key not in packet or packet.get(key) in (None, "", [])]
+            if missing_packet:
+                errors.append("v3.5 promotion_packet missing " + ", ".join(missing_packet))
+
+    surfaces = _kaxis_v35_surfaces(card)
+    risk_effective = str(card.get("risk_effective") or "").strip()
+    if _kaxis_v35_requires_security_scan(card, surfaces, risk_effective):
+        scan = metadata.get("security_scan_result")
+        if not _kaxis_non_empty_dict(scan):
+            errors.append("v3.5 security_scan_result metadata is required")
+        else:
+            required = ["scanner_agent", "tool", "result", "findings_summary"]
+            missing_scan = [
+                key for key in required
+                if not _kaxis_non_empty_string(scan.get(key), 4)
+            ]
+            if missing_scan:
+                errors.append("v3.5 security_scan_result missing " + ", ".join(missing_scan))
+            if not _kaxis_non_empty_string_list(scan.get("scope")):
+                errors.append("v3.5 security_scan_result scope must be a non-empty string array")
+            if not _kaxis_non_empty_string_list(scan.get("evidence_refs")):
+                errors.append("v3.5 security_scan_result evidence_refs must be a non-empty string array")
+            if not _kaxis_v35_has_security_tool([
+                scan.get("scanner_agent"),
+                scan.get("tool"),
+            ]):
+                errors.append("v3.5 security_scan_result must reference Codex Security or cybersecurity")
+            result = str(scan.get("result") or "").strip().upper()
+            if result not in {"PASS", "WAIVED"}:
+                errors.append("v3.5 security_scan_result result must be PASS or WAIVED")
+            if scan.get("blocking_findings") is True and not _kaxis_non_empty_dict(metadata.get("security_exception")):
+                errors.append("v3.5 security_scan_result blocking findings require security_exception")
+
+    return errors
+
 
 def _kaxis_extract_card(body: object) -> tuple[Optional[dict[str, Any]], Optional[str]]:
     raw = str(body or "").strip()
@@ -256,6 +594,8 @@ def _kaxis_validate_card_v2(card: dict[str, Any], assignee: object) -> list[str]
     if risk == "R4-production-critical" and card.get("codex_mode") != "required":
         errors.append("codex_mode must be required for R4-production-critical")
 
+    errors.extend(_kaxis_validate_v35_card(card, risk))
+
     return errors
 
 
@@ -411,6 +751,13 @@ def _kaxis_completion_gate_error(
             shown += f"; +{len(errors) - 8} more"
         return "KAXIS v2 completion gate: " + shown
 
+    v35_completion_errors = _kaxis_validate_v35_completion(card, metadata)
+    if v35_completion_errors:
+        shown = "; ".join(v35_completion_errors[:8])
+        if len(v35_completion_errors) > 8:
+            shown += f"; +{len(v35_completion_errors) - 8} more"
+        return "KAXIS v3.5 completion gate: " + shown
+
     risk = card.get("risk_class")
     if risk in {"R0-docs-only", "R1-dev-safe"}:
         return None
