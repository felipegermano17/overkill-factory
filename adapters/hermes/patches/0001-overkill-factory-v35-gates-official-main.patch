diff --git a/tests/hermes_cli/test_overkill_factory_v35_gate.py b/tests/hermes_cli/test_overkill_factory_v35_gate.py
new file mode 100644
index 0000000..3a9e0ce
--- /dev/null
+++ b/tests/hermes_cli/test_overkill_factory_v35_gate.py
@@ -0,0 +1,207 @@
+from __future__ import annotations
+
+import argparse
+import importlib.util
+import json
+import sys
+from pathlib import Path
+
+import pytest
+from fastapi import FastAPI
+from fastapi.testclient import TestClient
+
+from hermes_cli import kanban as kb_cli
+from hermes_cli import kanban_db as kb
+
+
+@pytest.fixture
+def kanban_home(tmp_path, monkeypatch):
+    home = tmp_path / ".hermes"
+    home.mkdir()
+    monkeypatch.setenv("HERMES_HOME", str(home))
+    monkeypatch.setattr(Path, "home", lambda: tmp_path)
+    db_path = kb.kanban_db_path(board="default")
+    kb._INITIALIZED_PATHS.discard(str(db_path.resolve()))
+    kb.init_db()
+    return home
+
+
+@pytest.fixture
+def conn(kanban_home):
+    with kb.connect() as c:
+        yield c
+
+
+def _load_dashboard_router():
+    repo_root = Path(__file__).resolve().parents[2]
+    plugin_file = repo_root / "plugins" / "kanban" / "dashboard" / "plugin_api.py"
+    spec = importlib.util.spec_from_file_location(
+        "overkill_factory_dashboard_test",
+        plugin_file,
+    )
+    assert spec and spec.loader
+    mod = importlib.util.module_from_spec(spec)
+    sys.modules[spec.name] = mod
+    spec.loader.exec_module(mod)
+    return mod.router
+
+
+@pytest.fixture
+def client(kanban_home):
+    app = FastAPI()
+    app.include_router(_load_dashboard_router(), prefix="/api/plugins/kanban")
+    return TestClient(app)
+
+
+def _card(**overrides):
+    card = {
+        "factory_method_version": kb.OVERKILL_FACTORY_VERSION,
+        "phase": "execution",
+        "surfaces": ["frontend", "security"],
+        "risk_initial": "R2-product",
+        "risk_effective": "R2-product",
+        "authority_max": "code_only",
+        "owner_worker": "product-face",
+        "executor_identity": "implementation-worker",
+        "reviewer_identity": "independent-reviewer",
+        "runtime_contract": {"runner": "codex"},
+        "security_contract": {"surface": "security"},
+        "forbidden_actions": ["deploy", "secrets"],
+        "done_definition": {"requires_receipt_five": True},
+        "kanban_transition_event_ref": "evt-ready",
+        "product_face_packet": {"screenshots": ["desktop", "mobile"]},
+        "security_scan_packet": {"tool": "codex-security"},
+    }
+    card.update(overrides)
+    return json.dumps(card)
+
+
+def _receipt_metadata(**overrides):
+    metadata = {
+        "receipt_five": {
+            "changed_files": ["app.py"],
+            "evidence_refs": ["validation/report.md"],
+            "verification": {"passed": True},
+            "independent_review": {"passed": True},
+            "next_action": "promote",
+        },
+        "kanban_transition_event": {"id": "evt-done"},
+        "product_face_result": {"status": "PASS", "evidence_refs": ["shot.png"]},
+        "security_scan_result": {"status": "PASS", "findings": []},
+    }
+    metadata.update(overrides)
+    return metadata
+
+
+def _todo_task(conn, body):
+    parent = kb.create_task(conn, title="parent")
+    child = kb.create_task(conn, title="child", body=body, parents=[parent])
+    conn.execute("UPDATE tasks SET status='done' WHERE id=?", (parent,))
+    assert kb.get_task(conn, child).status == "todo"
+    return child
+
+
+def test_overkill_ready_gate_blocks_missing_product_face_packet(conn):
+    body = _card(product_face_packet=None)
+    task_id = _todo_task(conn, body)
+
+    ok, error = kb.promote_task(conn, task_id, actor="tester", force=True)
+
+    assert ok is False
+    assert "Overkill Factory ready gate" in error
+    assert "product_face_packet" in error
+    assert kb.get_task(conn, task_id).status == "todo"
+
+
+def test_overkill_ready_gate_allows_complete_card(conn):
+    task_id = _todo_task(conn, _card())
+
+    ok, error = kb.promote_task(conn, task_id, actor="tester")
+
+    assert ok is True
+    assert error is None
+    assert kb.get_task(conn, task_id).status == "ready"
+
+
+def test_overkill_completion_gate_blocks_missing_results(conn):
+    task_id = kb.create_task(conn, title="done blocked", body=_card())
+
+    with pytest.raises(ValueError, match="receipt_five"):
+        kb.complete_task(conn, task_id, metadata={})
+
+    assert kb.get_task(conn, task_id).status == "ready"
+    event = conn.execute(
+        "SELECT kind FROM task_events "
+        "WHERE task_id = ? AND kind = 'completion_blocked_overkill_gate'",
+        (task_id,),
+    ).fetchone()
+    assert event is not None
+
+
+def test_overkill_completion_gate_requires_real_quasar_auditor(conn):
+    body = _card(
+        surfaces=["solana", "quasar", "security"],
+        product_face_packet=None,
+        onchain_work_package={"program": "quasar"},
+        auditor_packet={"corpus": "solanabr/Auditor"},
+    )
+    task_id = kb.create_task(conn, title="auditor blocked", body=body)
+    metadata = _receipt_metadata(
+        product_face_result=None,
+        auditor_result={"audit_mode": "preflight", "status": "PASS"},
+    )
+
+    with pytest.raises(ValueError, match="audit_mode=code_audit"):
+        kb.complete_task(conn, task_id, metadata=metadata)
+
+
+def test_overkill_completion_gate_allows_full_receipt(conn):
+    task_id = kb.create_task(conn, title="done allowed", body=_card())
+
+    assert kb.complete_task(conn, task_id, metadata=_receipt_metadata()) is True
+    assert kb.get_task(conn, task_id).status == "done"
+
+
+def test_overkill_cli_completion_reports_gate_without_traceback(
+    conn,
+    kanban_home,
+    capsys,
+):
+    task_id = kb.create_task(conn, title="cli blocked", body=_card())
+    args = argparse.Namespace(
+        task_ids=[task_id],
+        result=None,
+        summary=None,
+        metadata="{}",
+    )
+
+    rc = kb_cli._cmd_complete(args)
+
+    captured = capsys.readouterr()
+    assert rc == 1
+    assert "cannot complete" in captured.err
+    assert "Overkill Factory completion gate" in captured.err
+
+
+def test_overkill_dashboard_ready_move_returns_409(client, conn):
+    task_id = _todo_task(conn, _card(product_face_packet=None))
+
+    response = client.patch(
+        f"/api/plugins/kanban/tasks/{task_id}",
+        json={"status": "ready"},
+    )
+
+    assert response.status_code == 409
+    assert "product_face_packet" in response.json()["detail"]
+
+
+def test_overkill_dashboard_done_move_returns_409(client, conn):
+    task_id = kb.create_task(conn, title="dashboard done blocked", body=_card())
+
+    response = client.patch(
+        f"/api/plugins/kanban/tasks/{task_id}",
+        json={"status": "done", "metadata": {}},
+    )
+
+    assert response.status_code == 409
+    assert "Overkill Factory completion gate" in response.json()["detail"]
