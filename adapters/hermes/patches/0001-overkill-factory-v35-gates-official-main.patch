+def _overkill_extract_json_object(text: Optional[str]) -> Optional[dict[str, Any]]:
+    if not text or OVERKILL_FACTORY_VERSION not in text:
+        return None
+    candidates: list[str] = []
+    candidates.extend(
+        match.group(1)
+        for match in re.finditer(r"```(?:json)?\s*(\{.*?\})\s*```", text, re.S)
+    )
+    candidates.append(text.strip())
+    start = text.find("{")
+    end = text.rfind("}")
+    if start >= 0 and end > start:
+        candidates.append(text[start : end + 1])
+    for candidate in candidates:
+        try:
+            payload = json.loads(candidate)
+        except json.JSONDecodeError:
+            continue
+        if (
+            isinstance(payload, dict)
+            and payload.get("factory_method_version") == OVERKILL_FACTORY_VERSION
+        ):
+            return payload
+    return None
+
+
+def _overkill_card_for_task(
+    conn: sqlite3.Connection,
+    task_id: str,
+) -> Optional[dict[str, Any]]:
+    row = conn.execute("SELECT body FROM tasks WHERE id = ?", (task_id,)).fetchone()
+    if row is None:
+        return None
+    return _overkill_extract_json_object(row["body"])
+
+
+def _overkill_text_values(value: Any) -> list[str]:
+    if isinstance(value, str):
+        return [value.casefold()]
+    if isinstance(value, dict):
+        out: list[str] = []
+        for item in value.values():
+            out.extend(_overkill_text_values(item))
+        return out
+    if isinstance(value, (list, tuple, set)):
+        out = []
+        for item in value:
+            out.extend(_overkill_text_values(item))
+        return out
+    return []
+
+
+def _overkill_card_mentions(card: dict[str, Any], *needles: str) -> bool:
+    haystack = " ".join(_overkill_text_values(card))
+    return any(needle.casefold() in haystack for needle in needles)
+
+
+def _overkill_truthy_mapping(value: Any) -> bool:
+    return isinstance(value, dict) and bool(value)
+
+
+def _overkill_missing_common_card_fields(card: dict[str, Any]) -> list[str]:
+    missing = [key for key in _OVERKILL_REQUIRED_CARD_FIELDS if not card.get(key)]
+    if card.get("executor_identity") == card.get("reviewer_identity"):
+        missing.append("reviewer_identity_different_from_executor")
+    return missing
+
+
+def _overkill_ready_gate_error(conn: sqlite3.Connection, task_id: str) -> Optional[str]:
+    card = _overkill_card_for_task(conn, task_id)
+    if card is None:
+        return None
+
+    missing = _overkill_missing_common_card_fields(card)
+    if _overkill_card_mentions(card, "frontend", "ui", "product face", "mobile"):
+        if not _overkill_truthy_mapping(card.get("product_face_packet")):
+            missing.append("product_face_packet")
+    if _overkill_card_mentions(card, "onchain", "solana", "quasar"):
+        if not _overkill_truthy_mapping(card.get("onchain_work_package")):
+            missing.append("onchain_work_package")
+        if not _overkill_truthy_mapping(card.get("auditor_packet")):
+            missing.append("auditor_packet")
+    if _overkill_card_mentions(card, "r3", "r4", "security", "production"):
+        if not _overkill_truthy_mapping(card.get("security_scan_packet")):
+            missing.append("security_scan_packet")
+    if _overkill_card_mentions(card, "r4", "production"):
+        if not _overkill_truthy_mapping(card.get("human_gate")):
+            missing.append("human_gate")
+        if not card.get("rollback_plan"):
+            missing.append("rollback_plan")
+
+    if missing:
+        return "Overkill Factory ready gate: missing " + ", ".join(sorted(set(missing)))
+    return None
+
+
+def overkill_ready_gate_error(
+    conn: sqlite3.Connection,
+    task_id: str,
+) -> Optional[str]:
+    return _overkill_ready_gate_error(conn, task_id)
+
+
+def _overkill_completion_gate_error(
+    conn: sqlite3.Connection,
+    task_id: str,
+    metadata: Optional[dict],
+) -> Optional[str]:
+    card = _overkill_card_for_task(conn, task_id)
+    if card is None:
+        return None
+
+    missing: list[str] = []
+    if not isinstance(metadata, dict):
+        metadata = {}
+    receipt = metadata.get("receipt_five")
+    if not isinstance(receipt, dict):
+        missing.append("receipt_five")
+        receipt = {}
+    for key in _OVERKILL_REQUIRED_RECEIPT_FIELDS:
+        if not receipt.get(key):
+            missing.append(f"receipt_five.{key}")
+    if not _overkill_truthy_mapping(metadata.get("kanban_transition_event")):
+        missing.append("kanban_transition_event")
+    if _overkill_card_mentions(card, "frontend", "ui", "product face", "mobile"):
+        if not _overkill_truthy_mapping(metadata.get("product_face_result")):
+            missing.append("product_face_result")
+    if _overkill_card_mentions(card, "onchain", "solana", "quasar"):
+        auditor = metadata.get("auditor_result")
+        if not _overkill_truthy_mapping(auditor):
+            missing.append("auditor_result")
+        elif auditor.get("audit_mode") != "code_audit":
+            missing.append("auditor_result.audit_mode=code_audit")
+    if _overkill_card_mentions(card, "security", "onchain", "solana", "quasar", "r3", "r4"):
+        if not _overkill_truthy_mapping(metadata.get("security_scan_result")):
+            missing.append("security_scan_result")
+    if _overkill_card_mentions(card, "r3", "r4", "production"):
+        human = metadata.get("human_gate_record")
+        if not _overkill_truthy_mapping(human):
+            missing.append("human_gate_record")
+        elif human.get("decision") != "approved":
+            missing.append("human_gate_record.decision=approved")
+    if card.get("remote_proof_required") and not _overkill_truthy_mapping(
+        metadata.get("remote_proof_result")
+    ):
+        missing.append("remote_proof_result")
+
+    if missing:
+        return "Overkill Factory completion gate: missing " + ", ".join(sorted(set(missing)))
+    return None
+
+
+def overkill_completion_gate_error(
+    conn: sqlite3.Connection,
+    task_id: str,
+    metadata: Optional[dict],
+) -> Optional[str]:
+    return _overkill_completion_gate_error(conn, task_id, metadata)
+
 # A running task's claim is valid for 15 minutes by default; after that the
