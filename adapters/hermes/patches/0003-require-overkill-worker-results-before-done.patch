+def _worker_result(record_type: str, worker_id: str, *, result: str = "PASS", **extra: object) -> dict:
+    record = {
+        "record_type": record_type,
+        "worker": {"id": worker_id, "name": worker_id},
+        "card_ref": {"card_id": "OFP-V35-TEST", "slice_id": "OVERKILL_FACTORY_V35_TEST"},
+        "result": result,
+        "blocking_findings": False,
+        "findings_summary": "Deterministic worker-result fixture passed.",
+        "tool_or_profile": f"pytest:{worker_id}",
+        "executed_by": "pytest",
+        "evidence_refs": ["tests/hermes_cli/test_overkill_factory_v35_gate.py"],
+        "evidence_kind": "real",
+        "reusable_for_product": False,
+        "next_action": "Keep the worker result attached to completion metadata.",
+    }
+    record.update(extra)
+    return record
+
+
+def _product_face_result() -> dict:
+    return _worker_result(
+        "product_face_result",
+        "product-face",
+        screenshots=["validation/product-face/screenshots/desktop.png"],
+        viewports=["desktop 1440x900", "mobile 390x844"],
+        checked_states=["default", "loading", "error", "success"],
+        journeys=["open target", "inspect evidence"],
+        accessibility={"status": "pass"},
+        overlap={"status": "pass"},
+        performance_note="Static regression fixture performance note is present.",
+    )
+
+
+def _auditor_code_audit_result() -> dict:
