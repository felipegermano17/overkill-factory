+def test_v35_product_face_completion_requires_product_face_result(kanban_home: Path) -> None:
+    card = _base_card(owner="frontend", surfaces=["ux", "frontend"], phase="F13")
+
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="product face completion fixture",
+            body=_body(card),
+            assignee="frontend",
+            initial_status="blocked",
+        )
+        ok, err = kb.promote_task(conn, tid, actor="pytest")
+        assert ok is True
+        assert err is None
+
+        with pytest.raises(ValueError, match="product_face_result metadata is required"):
+            kb.complete_task(
+                conn,
+                tid,
+                result="missing product face proof",
+                summary="Receipt Five exists but browser/product evidence is missing",
+                metadata=_receipt_metadata(include_scan=False),
+            )
+        assert kb.get_task(conn, tid).status == "ready"
+
+        metadata = _receipt_metadata(include_scan=False)
+        metadata["product_face_result"] = _product_face_result()
+        assert kb.complete_task(
+            conn,
+            tid,
+            result="product face proof passed",
+            summary="Receipt Five and Product Face result accepted",
+            metadata=metadata,
+        )
+        assert kb.get_task(conn, tid).status == "done"
+
+
+def test_v35_onchain_done_requires_real_auditor_result(kanban_home: Path) -> None:
+    card = _base_card(
+        owner="protocol",
+        surfaces=["solana-quasar", "account-pda", "cpi", "compute-units"],
+        risk="R3-financial-critical",
+        phase="F13",
+    )
+    card["onchain_work_package"] = _onchain_package(auditor_required=True)
+    card["security_scan_packet"] = _security_scan_packet()
+
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="onchain completion fixture",
+            body=_body(card),
+            assignee="protocol",
+            initial_status="blocked",
+        )
+        ok, err = kb.promote_task(conn, tid, actor="pytest")
+        assert ok is True
+        assert err is None
+
+        metadata = _receipt_metadata(include_scan=True)
+        metadata["auditor_result"] = _worker_result(
+            "auditor_result",
+            "solana-quasar-auditor",
+            audit_mode="preflight",
+            preflight_only=True,
+        )
+        metadata["qa_verification_result"] = _worker_result("qa_verification_result", "qa-verification-worker")
+        metadata["independent_review_result"] = _worker_result("independent_review_result", "independent-reviewer")
+        metadata["human_gate_record"] = _human_gate_record()
+
+        with pytest.raises(ValueError, match="auditor_result audit_mode must be code_audit"):
+            kb.complete_task(
+                conn,
+                tid,
+                result="weak auditor proof",
+                summary="Preflight-only Auditor result is not enough for onchain done",
+                metadata=metadata,
+            )
+        assert kb.get_task(conn, tid).status == "ready"
+
+        metadata["auditor_result"] = _auditor_code_audit_result()
+        assert kb.complete_task(
+            conn,
+            tid,
+            result="auditor proof passed",
+            summary="Receipt Five, security scan and Auditor code-audit result accepted",
+            metadata=metadata,
+        )
+        assert kb.get_task(conn, tid).status == "done"
+
+
