+def test_patch_status_done_blocks_overkill_missing_product_face_result(client):
+    """Dashboard completion must surface the Factory done gate as HTTP 409."""
+    card = _base_card(owner="frontend", surfaces=["ux", "frontend"], phase="F13")
+    with kb.connect() as conn:
+        tid = kb.create_task(
+            conn,
+            title="product face dashboard done fixture",
+            body=_body(card),
+            assignee="frontend",
+            initial_status="blocked",
+        )
+        ok, err = kb.promote_task(conn, tid, actor="pytest")
+        assert ok is True
+        assert err is None
+
+    r = client.patch(
+        f"/api/plugins/kanban/tasks/{tid}",
+        json={
+            "status": "done",
+            "summary": "Receipt exists but Product Face result is missing",
+            "metadata": _receipt_metadata(include_scan=False),
+        },
+    )
+
+    assert r.status_code == 409
+    assert "product_face_result metadata is required" in r.json()["detail"]
+    with kb.connect() as conn:
+        assert kb.get_task(conn, tid).status == "ready"
+
+
