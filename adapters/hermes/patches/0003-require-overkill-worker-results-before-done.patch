+def _overkill_v35_validate_worker_result(
+    metadata: dict,
+    key: str,
+    errors: list[str],
+    *,
+    allowed_results: set[str] | None = None,
+) -> Optional[dict[str, Any]]:
+    record = metadata.get(key)
+    if not _overkill_non_empty_dict(record):
+        errors.append(f"v3.5 {key} metadata is required")
+        return None
+
+    if record.get("record_type") and record.get("record_type") != key:
+        errors.append(f"v3.5 {key} record_type must be {key}")
+
+    worker = record.get("worker")
+    if not _overkill_non_empty_dict(worker) or not _overkill_non_empty_string(worker.get("id")):
+        errors.append(f"v3.5 {key} worker.id is required")
+    card_ref = record.get("card_ref")
+    if not _overkill_non_empty_dict(card_ref) or not _overkill_non_empty_string(card_ref.get("card_id")):
+        errors.append(f"v3.5 {key} card_ref.card_id is required")
+
+    required = ["findings_summary", "tool_or_profile", "executed_by", "evidence_kind", "next_action"]
+    missing = [field for field in required if not _overkill_non_empty_string(record.get(field), 3)]
+    if missing:
+        errors.append(f"v3.5 {key} missing " + ", ".join(missing))
+    if not _overkill_non_empty_string_list(record.get("evidence_refs")):
+        errors.append(f"v3.5 {key} evidence_refs must be a non-empty string array")
+
+    result = str(record.get("result") or "").strip().upper()
+    allowed = allowed_results or {"PASS", "WAIVED"}
+    if result not in allowed:
+        errors.append(f"v3.5 {key} result must be " + " or ".join(sorted(allowed)))
+    if record.get("blocking_findings") is True and not _overkill_non_empty_dict(record.get("waiver")):
+        errors.append(f"v3.5 {key} blocking findings require waiver")
+    if result == "WAIVED" and not _overkill_non_empty_dict(record.get("waiver")):
+        errors.append(f"v3.5 {key} WAIVED result requires waiver")
+    return record
+
+
+def _overkill_v35_validate_product_face_result(metadata: dict, errors: list[str]) -> None:
+    record = _overkill_v35_validate_worker_result(
+        metadata,
+        "product_face_result",
+        errors,
+        allowed_results={"PASS"},
+    )
+    if not record:
+        return
+    list_fields = ["screenshots", "viewports", "checked_states", "journeys"]
+    missing_lists = [field for field in list_fields if not _overkill_non_empty_string_list(record.get(field))]
+    if missing_lists:
+        errors.append("v3.5 product_face_result missing " + ", ".join(missing_lists))
+    for field in ("accessibility", "overlap"):
+        if not _overkill_non_empty_dict(record.get(field)):
+            errors.append(f"v3.5 product_face_result {field} must be an object")
+    if not _overkill_non_empty_string(record.get("performance_note"), 10):
+        errors.append("v3.5 product_face_result performance_note is required")
+
+
+def _overkill_v35_validate_auditor_result(metadata: dict, errors: list[str]) -> None:
+    record = _overkill_v35_validate_worker_result(
+        metadata,
+        "auditor_result",
+        errors,
+        allowed_results={"PASS", "WAIVED"},
+    )
+    if not record:
+        return
+    result = str(record.get("result") or "").strip().upper()
+    if result == "WAIVED":
+        return
+    audit_mode = str(record.get("audit_mode") or "").strip().lower()
+    if audit_mode != "code_audit":
+        errors.append("v3.5 auditor_result audit_mode must be code_audit for PASS")
+    if record.get("preflight_only") is True:
+        errors.append("v3.5 auditor_result preflight_only cannot PASS")
+    required_objects = [
+        "quasar_toolchain_proof",
+        "checklist_coverage",
+        "instruction_matrix",
+        "state_model",
+    ]
+    missing_objects = [field for field in required_objects if not _overkill_non_empty_dict(record.get(field))]
+    if missing_objects:
+        errors.append("v3.5 auditor_result missing " + ", ".join(missing_objects))
+    if not record.get("known_vector_coverage"):
+        errors.append("v3.5 auditor_result known_vector_coverage is required")
+
+
+def _overkill_v35_validate_human_gate_record(metadata: dict, errors: list[str]) -> None:
+    record = metadata.get("human_gate_record")
+    if not _overkill_non_empty_dict(record):
+        errors.append("v3.5 human_gate_record metadata is required")
+        return
+    required = ["decision", "human_actor", "decision_at", "risk_owner", "security_owner"]
+    missing = [field for field in required if not _overkill_non_empty_string(record.get(field), 3)]
+    if missing:
+        errors.append("v3.5 human_gate_record missing " + ", ".join(missing))
+    decision = str(record.get("decision") or "").strip().lower()
+    if decision not in {"approved", "waived"}:
+        errors.append("v3.5 human_gate_record decision must be approved or waived")
+    if not _overkill_non_empty_string_list(record.get("evidence_refs")):
+        errors.append("v3.5 human_gate_record evidence_refs must be a non-empty string array")
+
+
 def _overkill_validate_v35_completion(card: dict[str, Any], metadata: Optional[dict]) -> list[str]:
     if not _overkill_is_v35_card(card):
         return []
@@ -494,6 +600,31 @@ def _overkill_validate_v35_completion(card: dict[str, Any], metadata: Optional[dict
             if scan.get("blocking_findings") is True and not _overkill_non_empty_dict(metadata.get("security_exception")):
                 errors.append("v3.5 security_scan_result blocking findings require security_exception")

+    if surfaces & _Overkill_V35_PRODUCT_FACE_SURFACES:
+        _overkill_v35_validate_product_face_result(metadata, errors)
+
+    if surfaces & _Overkill_V35_ONCHAIN_SURFACES:
+        _overkill_v35_validate_auditor_result(metadata, errors)
+
+    review = card.get("review") if isinstance(card.get("review"), dict) else {}
+    if review.get("QA_required") is True:
+        _overkill_v35_validate_worker_result(metadata, "qa_verification_result", errors)
+    if review.get("independent_review_required") is True:
+        _overkill_v35_validate_worker_result(metadata, "independent_review_result", errors)
+
+    human_gate_required = (
+        risk_effective in {"R3", "R4"}
+        or review.get("CTO_gate_required") is True
+        or review.get("human_owner_gate_required") is True
+        or card.get("human_gate_required") is True
+    )
+    if human_gate_required:
+        _overkill_v35_validate_human_gate_record(metadata, errors)
+
+    runtime_contract = card.get("runtime_contract") if isinstance(card.get("runtime_contract"), dict) else {}
+    if card.get("remote_proof_required") is True or runtime_contract.get("remote_proof_required") is True:
+        _overkill_v35_validate_worker_result(metadata, "remote_proof_result", errors)
+
     return errors


