+def _guard_overkill_link_edit(
+    conn: sqlite3.Connection,
+    parent_id: str,
+    child_id: str,
+) -> None:
+    """Block manual dependency edits for Overkill Factory-controlled tasks."""
+    parent = kanban_db.get_task(conn, parent_id)
+    child = kanban_db.get_task(conn, child_id)
+    missing = parent_id if parent is None else child_id if child is None else None
+    if missing is not None:
+        raise HTTPException(status_code=404, detail=f"task {missing} not found")
+    touches_factory = (
+        _is_overkill_factory_card(parent)
+        or _is_overkill_worker_subtask(parent)
+        or _is_overkill_factory_card(child)
+        or _is_overkill_worker_subtask(child)
+    )
+    if touches_factory:
+        raise HTTPException(
+            status_code=409,
+            detail=(
+                "Overkill Factory card dependencies cannot be edited from "
+                "dashboard/API; regenerate worker subtasks through the Factory "
+                "gate or use an explicit operator-safe dependency workflow."
+            ),
+        )
+
