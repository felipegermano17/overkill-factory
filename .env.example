# Copy values into your local environment file if your tooling uses dotenv.
# Keep real credentials out of commits.

HERMES_BIN=hermes
HERMES_PROFILES_DIR=./.hermes-profiles
OVERKILL_FACTORY_REPO=.

# Optional Control Tower. Hermes and receipts remain the source of truth.
DISCORD_CONTROL_TOWER_ENABLED=false
DISCORD_BOT_TOKEN=example
DISCORD_GUILD_ID=example-guild-id
DISCORD_STATUS_CHANNEL_ID=example-status-channel
DISCORD_APPROVAL_CHANNEL_ID=example-approval-channel

# Optional tools used by specific workers.
OPENAI_API_KEY=example
CRABBOX_BIN=crabbox
AUDITOR_BIN=auditor
